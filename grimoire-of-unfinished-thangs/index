    '#FF0004', '#1a3300', '#FCFFDD', '#FF6600', '#010D25', '#C9FF4B',
    '#000F01', '#FFE9DD', '#FF0004', '#e8ff90', '#010D25', '#FCFFDD',
  ];

  /**
   * getSegColor — pure index-based lookup so every consecutive segment
   * gets a strictly different colour regardless of category grouping.
   * This guarantees maximum visual variety even when many same-category
   * quests appear back-to-back.
   */
  function getSegColor(quest, globalIdx) {
