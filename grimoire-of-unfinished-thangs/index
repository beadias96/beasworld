  <!-- ================================================================
       JAVASCRIPT
       Sections:
         A. Audio engine
         B. Border canvas (growing ornate border animation)
         C. Sparkle canvas (ambient particles)
         D. Quest data
         E. Time slider
         F. Wheel drawing (segments + mandala hub + frame SVG)
         G. Arc lever (quarter-arc drag-to-spin)
         H. Spin mechanics
         I. Pamphlet modal
         J. Envelope modal (prompt generator)
         K. Utility / FX
         L. Init
  ================================================================ -->
  <script>
  'use strict';

  /* ──────────────────────────────────────────────────────────
     A. AUDIO ENGINE
     All sound synthesis uses Web Audio API.
     getAudio() lazily creates and resumes the AudioContext.
  ────────────────────────────────────────────────────────── */
  let audioCtx = null;

  function getAudio() {
    if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    if (audioCtx.state === 'suspended') audioCtx.resume();
    return audioCtx;
  }

  // ── Mobile audio unlock ────────────────────────────────────────
  // iOS and some Android browsers suspend AudioContext until a user
  // gesture has explicitly resumed it. We create and immediately
  // resume the context on the very first touch/click anywhere on
  // the page so that sound is ready before the first spin.
  function unlockAudio() {
    if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    if (audioCtx.state === 'suspended') {
      audioCtx.resume().catch(() => {});
    }
    // Play a silent buffer to fully unlock on iOS
    try {
      const buf = audioCtx.createBuffer(1, 1, 22050);
      const src = audioCtx.createBufferSource();
      src.buffer = buf;
      src.connect(audioCtx.destination);
      src.start(0);
    } catch (e) {}
    document.removeEventListener('touchstart', unlockAudio, true);
    document.removeEventListener('mousedown',  unlockAudio, true);
  }
  document.addEventListener('touchstart', unlockAudio, true);
  document.addEventListener('mousedown',  unlockAudio, true);

  /**
   * playLeverCreak(velocity, phase)
   * Industrial iron-grinding sound for the crank lever.
   * @param {number} velocity  0–1 — drag speed, affects pitch and volume
   * @param {'start'|'mid'|'end'} phase  'start'/'end' add a metallic clunk
   */
  function playLeverCreak(velocity = 0.5, phase = 'mid') {
    try {
      const ctx = getAudio();
      const t   = ctx.currentTime;
      const v   = Math.max(0.04, Math.min(1, velocity));

      // Correlated low-frequency noise → bandpass → tanh distortion
      const sr  = ctx.sampleRate;
      const dur = 0.06 + v * 0.14;
      const buf = ctx.createBuffer(1, Math.floor(sr * dur), sr);
      const d   = buf.getChannelData(0);
      let s1 = 0, s2 = 0;
      for (let i = 0; i < d.length; i++) {
        s1 = s1 * 0.88 + (Math.random() * 2 - 1) * 0.12;
        s2 = s2 * 0.96 + s1 * 0.04;
        d[i] = s2 * Math.sin(i / d.length * Math.PI) * 1.5;
      }

      const src  = ctx.createBufferSource(); src.buffer = buf;
      const bp   = ctx.createBiquadFilter(); bp.type = 'bandpass'; bp.frequency.value = 160 + v * 80; bp.Q.value = 2.2;
      const dist = ctx.createWaveShaper();
      const crv  = new Float32Array(128);
      for (let i = 0; i < 128; i++) { const x = i / 63.5 - 1; crv[i] = Math.tanh(x * 2.5) * 0.7; }
      dist.curve = crv;
      const g = ctx.createGain(); g.gain.setValueAtTime(0.4 * v, t); g.gain.exponentialRampToValueAtTime(0.001, t + dur + 0.05);

      src.connect(bp); bp.connect(dist); dist.connect(g); g.connect(ctx.destination);
      src.start(t);

      // Metallic clunk on start/end transitions
      if (phase === 'start' || phase === 'end') {
        const osc = ctx.createOscillator(); osc.type = 'sawtooth';
        const f0  = phase === 'start' ? 95 : 75;
        osc.frequency.setValueAtTime(f0, t);
        osc.frequency.exponentialRampToValueAtTime(f0 * 0.7, t + 0.22);

        const bpM = ctx.createBiquadFilter(); bpM.type = 'bandpass'; bpM.frequency.value = 320; bpM.Q.value = 5;
        const dM  = ctx.createWaveShaper();
        const cM  = new Float32Array(128);
        for (let i = 0; i < 128; i++) { const x = i / 63.5 - 1; cM[i] = Math.tanh(x * 3.5) * 0.5; }
        dM.curve = cM;
        const gM = ctx.createGain(); gM.gain.setValueAtTime(0.18 * v, t); gM.gain.exponentialRampToValueAtTime(0.001, t + 0.28);

        osc.connect(dM); dM.connect(bpM); bpM.connect(gM); gM.connect(ctx.destination);
        osc.start(t); osc.stop(t + 0.3);

        // Sub thud
        const b2 = ctx.createBuffer(1, Math.floor(sr * 0.08), sr);
        const d2 = b2.getChannelData(0);
        for (let i = 0; i < d2.length; i++) d2[i] = (Math.random() * 2 - 1) * Math.exp(-i / (d2.length * 0.15));
        const s3 = ctx.createBufferSource(); s3.buffer = b2;
        const lp = ctx.createBiquadFilter(); lp.type = 'lowpass'; lp.frequency.value = 100;
        const g3 = ctx.createGain(); g3.gain.setValueAtTime(0.3 * v, t); g3.gain.exponentialRampToValueAtTime(0.001, t + 0.09);
        s3.connect(lp); lp.connect(g3); g3.connect(ctx.destination); s3.start(t);
      }
    } catch (e) { /* AudioContext may not be available */ }
  }

  /**
   * startWoodyRoll(speed) / stopWoodyRoll()
   * Continuous wood-on-wood rolling sound while the wheel spins.
   * Low-pass noise loop + periodic hollow-wood knocks.
   */
  let woodyNode = null, woodyGain = null, woodyKnocking = false;

  function startWoodyRoll(speed = 1) {
    stopWoodyRoll();
    try {
      const ctx = getAudio();
      const t   = ctx.currentTime;
      const sr  = ctx.sampleRate;
      const buf = ctx.createBuffer(1, Math.floor(sr * 0.8), sr);
      const d   = buf.getChannelData(0);
      let lp = 0;
      for (let i = 0; i < d.length; i++) { lp = lp * 0.96 + (Math.random() * 2 - 1) * 0.04; d[i] = lp; }

      const src = ctx.createBufferSource(); src.buffer = buf; src.loop = true;
      const lp1 = ctx.createBiquadFilter(); lp1.type = 'lowpass';  lp1.frequency.value = 140; lp1.Q.value = 1.2;
      const lp2 = ctx.createBiquadFilter(); lp2.type = 'bandpass'; lp2.frequency.value = 300; lp2.Q.value = 2.5;

      woodyGain = ctx.createGain(); woodyGain.gain.setValueAtTime(0, t); woodyGain.gain.linearRampToValueAtTime(0.22, t + 0.4);
      const mix = ctx.createGain();
      src.connect(lp1); lp1.connect(mix);
      src.connect(lp2); lp2.connect(mix);
      mix.connect(woodyGain); woodyGain.connect(ctx.destination);
      woodyNode = src; src.start(t);

      woodyKnocking = true;
      (function knock() {
        if (!woodyKnocking) return;
        try {
          const c2 = getAudio();
          const bl = Math.floor(c2.sampleRate * 0.055);
          const b2 = c2.createBuffer(1, bl, c2.sampleRate);
          const d2 = b2.getChannelData(0);
          for (let i = 0; i < bl; i++) d2[i] = (Math.random() * 2 - 1) * Math.exp(-i / (bl * 0.25));
          const s2 = c2.createBufferSource(); s2.buffer = b2;
          const f2 = c2.createBiquadFilter(); f2.type = 'bandpass'; f2.frequency.value = 180 + Math.random() * 100; f2.Q.value = 6;
          const g2 = c2.createGain(); g2.gain.setValueAtTime(0.18, c2.currentTime); g2.gain.exponentialRampToValueAtTime(0.001, c2.currentTime + 0.06);
          s2.connect(f2); f2.connect(g2); g2.connect(c2.destination); s2.start();
        } catch (e) {}
        if (woodyKnocking) setTimeout(knock, 95 + Math.random() * 60);
      })();
    } catch (e) {}
  }

  function stopWoodyRoll() {
    woodyKnocking = false;
    try {
      if (woodyGain) {
        const ctx = getAudio();
        woodyGain.gain.setValueAtTime(woodyGain.gain.value, ctx.currentTime);
        woodyGain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.55);
      }
      const node = woodyNode; woodyNode = null;
      setTimeout(() => { try { node && node.stop(); } catch(e){} woodyGain = null; }, 600);
    } catch (e) {}
  }

  /**
   * playMagicalSparkle()
   * Ascending pentatonic harp-bell shimmer that plays on result reveal.
   * Long tails that fade "into the distance".
   */
  function playMagicalSparkle() {
    try {
      const ctx = getAudio();
      const t   = ctx.currentTime;
      [392,523,659,784,1047,1319,1568,2093,2637].forEach((freq, i) => {
        const delay = i * 0.11;
        const dur   = 1.8 - i * 0.05;
        const o1 = ctx.createOscillator(); o1.type = 'sine'; o1.frequency.setValueAtTime(freq, t + delay); o1.frequency.linearRampToValueAtTime(freq * 1.008, t + delay + dur);
        const o2 = ctx.createOscillator(); o2.type = 'sine'; o2.frequency.setValueAtTime(freq * 2, t + delay);
        const g1 = ctx.createGain(); g1.gain.setValueAtTime(0, t + delay); g1.gain.linearRampToValueAtTime(0.07 + i * 0.005, t + delay + 0.03); g1.gain.exponentialRampToValueAtTime(0.0001, t + delay + dur);
        const g2 = ctx.createGain(); g2.gain.setValueAtTime(0.025, t + delay); g2.gain.exponentialRampToValueAtTime(0.0001, t + delay + dur * 0.8);
        o1.connect(g1); g1.connect(ctx.destination); o1.start(t + delay); o1.stop(t + delay + dur + 0.1);
        o2.connect(g2); g2.connect(ctx.destination); o2.start(t + delay); o2.stop(t + delay + dur);
      });
      // Trailing shimmer
      for (let i = 0; i < 6; i++) setTimeout(() => {
        try {
          const c2 = getAudio();
          const f  = [2200,3100,2700,3600,2400,3300][i];
          const o  = c2.createOscillator(); o.type = 'sine'; o.frequency.value = f; o.frequency.linearRampToValueAtTime(f * 1.02, c2.currentTime + 1.5);
          const g  = c2.createGain(); g.gain.setValueAtTime(0.04, c2.currentTime); g.gain.exponentialRampToValueAtTime(0.0001, c2.currentTime + 1.6);
          o.connect(g); g.connect(c2.destination); o.start(); o.stop(c2.currentTime + 1.7);
        } catch(e) {}
      }, 900 + i * 220);
    } catch (e) {}
  }


  /* ──────────────────────────────────────────────────────────
     B. BORDER CANVAS
     Organic ornate border that grows in from the center of each
     edge outward over ~20 seconds, then breathes continuously.
     Renders: main lines, alternating ornaments (tick/diamond/leaf),
     growing-tip vine curl, mid-edge diamonds, corner rosettes.
  ────────────────────────────────────────────────────────── */
  (function initBorderCanvas() {
    const cv  = document.getElementById('borderCanvas');
    const ctx = cv.getContext('2d');
    let W, H, t = 0, growth = 0;

    function resize() { W = cv.width = innerWidth; H = cv.height = innerHeight; }
    resize(); addEventListener('resize', resize);

    function drawEdge(x0, y0, x1, y1, p, flip, phase) {
      if (p <= 0) return;
      const ep = Math.min(p, 1);
      const dx = x1 - x0, dy = y1 - y0;
      const len = Math.sqrt(dx * dx + dy * dy);
      const ex = x0 + dx * ep, ey = y0 + dy * ep;
      const nx = -dy / len * (flip ? -1 : 1);
      const ny =  dx / len * (flip ? -1 : 1);
      const breath = 0.5 + 0.15 * Math.sin(t * 0.35 + phase);

      ctx.save();
      ctx.strokeStyle = '#C9FF4B';

      // Main line
      ctx.lineWidth = 1.4; ctx.globalAlpha = 0.55 * ep * breath;
      ctx.beginPath(); ctx.moveTo(x0, y0); ctx.lineTo(ex, ey); ctx.stroke();

      // Inner parallel
      ctx.lineWidth = 0.6; ctx.globalAlpha = 0.22 * ep * breath;
      ctx.beginPath(); ctx.moveTo(x0 + nx * 5, y0 + ny * 5); ctx.lineTo(ex + nx * 5, ey + ny * 5); ctx.stroke();

      // Decorations along edge
      const spacing = 48;
      const count   = Math.floor(len * ep / spacing);
      for (let i = 1; i <= count; i++) {
        const frac = i * spacing / len;
        if (frac > ep) break;
        const px = x0 + dx * frac, py = y0 + dy * frac;
        const grow = (Math.sin(t * 0.5 + i * 0.8 + phase) + 1) / 2;
        const ux = dx / len, uy = dy / len;
        switch (i % 3) {
          case 0: // Cross tick
            ctx.globalAlpha = (0.3 + 0.2 * grow) * ep; ctx.lineWidth = 1;
            ctx.beginPath(); ctx.moveTo(px + nx * 7, py + ny * 7); ctx.lineTo(px - nx * 4, py - ny * 4); ctx.stroke();
            ctx.beginPath(); ctx.moveTo(px + ux * 4, py + uy * 4); ctx.lineTo(px - ux * 4, py - uy * 4); ctx.stroke();
            break;
          case 1: { // Diamond
            const ds = 3.5 + grow * 2;
            ctx.globalAlpha = (0.35 + 0.2 * grow) * ep; ctx.lineWidth = 0.9;
            ctx.beginPath();
            ctx.moveTo(px + nx * ds, py + ny * ds); ctx.lineTo(px + ux * ds, py + uy * ds);
            ctx.lineTo(px - nx * ds, py - ny * ds); ctx.lineTo(px - ux * ds, py - uy * ds);
            ctx.closePath(); ctx.stroke();
            ctx.fillStyle = '#C9FF4B'; ctx.globalAlpha = 0.5 * grow * ep;
            ctx.beginPath(); ctx.arc(px, py, 1.2, 0, Math.PI * 2); ctx.fill();
            break;
          }
          case 2: { // Organic leaf
            const ls = 4 + grow * 5;
            ctx.globalAlpha = (0.2 + 0.15 * grow) * ep; ctx.lineWidth = 0.8;
            ctx.beginPath();
            ctx.moveTo(px, py);
            ctx.bezierCurveTo(px + nx*ls - ux*ls*.5, py + ny*ls - uy*ls*.5, px + nx*ls + ux*ls*.5, py + ny*ls + uy*ls*.5, px, py);
            ctx.stroke();
            break;
          }
        }
      }

      // Growing-tip vine curl
      if (ep > 0.04) {
        const curlR = 6 + 3 * Math.sin(t * 0.4 + phase);
        ctx.globalAlpha = 0.38 * Math.min(1, ep * 4); ctx.lineWidth = 0.9;
        ctx.beginPath(); ctx.arc(ex, ey, curlR, Math.atan2(dy, dx) + Math.PI * .5, Math.atan2(dy, dx) + Math.PI * 2.2); ctx.stroke();
      }
      ctx.restore();
    }

    function drawRosette(cx, cy, p, rot) {
      if (p <= 0) return;
      p = Math.min(p, 1);
      ctx.save(); ctx.translate(cx, cy); ctx.rotate(rot);
      const br = 0.7 + 0.3 * Math.sin(t * 0.4 + cx * 0.01);
      ctx.globalAlpha = 0.5 * p * br; ctx.strokeStyle = '#C9FF4B'; ctx.lineWidth = 1.3;
      ctx.beginPath(); ctx.arc(0, 0, 18, 0, Math.PI * 2 * p); ctx.stroke();
      ctx.globalAlpha = 0.3 * p; ctx.lineWidth = 0.7;
      ctx.beginPath(); ctx.arc(0, 0, 12, 0, Math.PI * 2 * p); ctx.stroke();
      for (let i = 0; i < Math.floor(12 * p); i++) {
        const sa = i * Math.PI * 2 / 12;
        ctx.globalAlpha = (0.2 + 0.15 * Math.sin(t * .5 + i)) * p; ctx.lineWidth = .7;
        ctx.beginPath(); ctx.moveTo(Math.cos(sa)*4, Math.sin(sa)*4); ctx.lineTo(Math.cos(sa)*16, Math.sin(sa)*16); ctx.stroke();
      }
      if (p > .7) {
        ctx.globalAlpha = 0.25 * p * br;
        for (let i = 0; i < 4; i++) {
          const a = i * Math.PI / 2;
          ctx.beginPath();
          ctx.moveTo(Math.cos(a)*3, Math.sin(a)*3);
          ctx.bezierCurveTo(Math.cos(a+.5)*14, Math.sin(a+.5)*14, Math.cos(a-.5)*14, Math.sin(a-.5)*14, Math.cos(a)*3, Math.sin(a)*3);
          ctx.strokeStyle = '#C9FF4B'; ctx.lineWidth = 1; ctx.stroke();
        }
      }
      ctx.globalAlpha = 0.7 * p; ctx.fillStyle = '#C9FF4B';
      ctx.beginPath(); ctx.arc(0, 0, 3 + Math.sin(t * .5) * .6, 0, Math.PI * 2); ctx.fill();
      ctx.restore();
    }

    function draw() {
      ctx.clearRect(0, 0, W, H);
      growth = Math.min(growth + 0.0008, 1);
      const M = 24;
      // Edges grow from midpoint outward
      drawEdge(W/2, M,   M,   M,   growth, false, 0);
      drawEdge(W/2, M,   W-M, M,   growth, true,  1);
      drawEdge(M,   H/2, M,   M,   growth, true,  2);
      drawEdge(M,   H/2, M,   H-M, growth, false, 3);
      drawEdge(W/2, H-M, M,   H-M, growth, true,  4);
      drawEdge(W/2, H-M, W-M, H-M, growth, false, 5);
      drawEdge(W-M, H/2, W-M, M,   growth, false, 6);
      drawEdge(W-M, H/2, W-M, H-M, growth, true,  7);

      // Corner rosettes bloom after edges meet
      const cg = Math.max(0, (growth - .55) / .45);
      drawRosette(M,   M,   cg,  Math.PI * .25);
      drawRosette(W-M, M,   cg,  Math.PI * .75);
      drawRosette(M,   H-M, cg, -Math.PI * .25);
      drawRosette(W-M, H-M, cg, -Math.PI * .75);

      // Mid-edge diamonds (appear at half growth)
      if (growth > .5) {
        const mg = Math.min(1, (growth - .5) / .5);
        [[W/2, M], [W/2, H-M], [M, H/2], [W-M, H/2]].forEach(([mx, my], idx) => {
          ctx.save();
          ctx.globalAlpha = 0.4 * mg * (0.7 + 0.3 * Math.sin(t * .4 + idx));
          ctx.strokeStyle = '#C9FF4B'; ctx.lineWidth = 0.9;
          ctx.beginPath(); ctx.moveTo(mx, my-4); ctx.lineTo(mx+4, my); ctx.lineTo(mx, my+4); ctx.lineTo(mx-4, my); ctx.closePath(); ctx.stroke();
          ctx.restore();
        });
      }
      t += 0.012;
      requestAnimationFrame(draw);
    }
    draw();
  })();


  /* ──────────────────────────────────────────────────────────
     C. SPARKLE CANVAS
     Ambient floating 8-pointed stars drifting upward.
  ────────────────────────────────────────────────────────── */
  (function initSparkleCanvas() {
    const cv  = document.getElementById('sparkleCanvas');
    const ctx = cv.getContext('2d');
    let W, H;
    function resize() { W = cv.width = innerWidth; H = cv.height = innerHeight; }
    resize(); addEventListener('resize', resize);

    const mkStar = (random) => ({
      x:  random ? Math.random() * 1600 : Math.random() * W,
      y:  random ? Math.random() * 1000 : Math.random() * H,
      sz: .3 + Math.random() * 1.2,
      a:  0,
      ma: .05 + Math.random() * .18,
      ph: Math.random() * Math.PI * 2,
      sp: .003 + Math.random() * .009,
      dr: (Math.random() - .5) * .055,
      vy: -.025 - Math.random() * .055,
    });

    // More stars — mix of drifting and near-static twinkling
    const stars = Array.from({ length: 60 }, () => mkStar(true));

    function draw8Star(x, y, r, alpha) {
      ctx.save(); ctx.globalAlpha = alpha; ctx.fillStyle = '#C9FF4B'; ctx.translate(x, y);
      ctx.beginPath();
      for (let i = 0; i < 8; i++) {
        const a  = i * Math.PI / 4;
        const rr = i % 2 === 0 ? r : r * .28;
        i === 0 ? ctx.moveTo(Math.cos(a)*rr, Math.sin(a)*rr) : ctx.lineTo(Math.cos(a)*rr, Math.sin(a)*rr);
      }
      ctx.closePath(); ctx.fill(); ctx.restore();
    }

    function tick() {
      ctx.clearRect(0, 0, W, H);
      stars.forEach(s => {
        s.ph += s.sp; s.x += s.dr; s.y += s.vy;
        s.a = Math.max(0, Math.sin(s.ph) * s.ma);
        if (s.y < -10 || (s.a <= 0 && s.ph > Math.PI * 1.5)) { Object.assign(s, mkStar(false)); s.ph = 0; }
        if (s.a > 0) draw8Star(s.x, s.y, s.sz * 3.5, s.a);
      });
      requestAnimationFrame(tick);
    }
    tick();
  })();


