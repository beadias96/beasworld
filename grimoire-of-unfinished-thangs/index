  /**
   * WHEEL_PALETTE — 30-entry hand-shuffled sequence using all 6 palette colours.
   * No two adjacent entries share the same colour family, and no cluster
   * of 3 is ever the same hue group. Designed so the wheel always looks
   * like a vivid stained-glass window regardless of how many segments show.
   */
  const WHEEL_PALETTE = [
    '#C9FF4B', '#FF0004', '#010D25', '#FFE9DD', '#1a3300', '#FCFFDD',
    '#FF6600', '#000F01', '#C9FF4B', '#010D25', '#FFE9DD', '#FF0004',
