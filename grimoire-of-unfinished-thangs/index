  /* ──────────────────────────────────────────────────────────
     E. TIME SLIDER
     5-stop snap slider.  Drag anywhere on the track.
     Uses the lever creak sound for haptic-like feedback.
  ────────────────────────────────────────────────────────── */
  const SLOTS      = ['5','15','30','60','2h'];
  const SLOT_NAMES = ['⚡ 5 minutes','☽ 15 minutes','✦ 30 minutes','☀ 1 hour','⚔ 2 hours+'];
  let currentSlot    = '5';
  let currentSlotIdx = 0;

  function setSlot(slotKey) {
    const idx = SLOTS.indexOf(slotKey);
    if (idx < 0) return;
    currentSlotIdx = idx;
    currentSlot    = slotKey;

    document.getElementById('slotName').textContent = SLOT_NAMES[idx];
    SLOTS.forEach((_, i) => {
      const lbl = document.getElementById('lbl-' + i);
      if (lbl) lbl.className = i === idx ? 'active-lbl' : '';
    });
    const cv = document.getElementById('wheel');
    cv.style.transition = 'opacity .18s';
    cv.style.opacity = '0';
    setTimeout(() => { drawWheel(); cv.style.opacity = '1'; }, 180);
  }

  function initTimeSlider() {
    const track = document.getElementById('timeSliderTrack');
    const knob  = document.getElementById('timeSliderKnob');
    const fill  = document.getElementById('sliderFill');
    if (!track || !knob || !fill) return;

    function pctForIdx(idx) { return idx / (SLOTS.length - 1); }

    function applyIdx(idx, animated = false) {
      const pct = pctForIdx(idx) * 100;
      if (animated) {
        knob.style.transition = 'left 0.25s cubic-bezier(0.34,1.4,0.64,1)';
        fill.style.transition  = 'width 0.25s ease';
      } else {
        knob.style.transition = 'none';
        fill.style.transition  = 'none';
      }
      knob.style.left = pct + '%';
      fill.style.width = pct + '%';
      track.setAttribute('aria-valuenow', idx);
      setSlot(SLOTS[idx]);
    }

    function idxFromClientX(clientX) {
      const rect = track.getBoundingClientRect();
      const pct  = Math.max(0, Math.min(1, (clientX - rect.left) / rect.width));
      return Math.round(pct * (SLOTS.length - 1));
    }

    applyIdx(0, true);

    let dragging = false;

    track.addEventListener('mousedown', e => {
      dragging = true;
      const idx = idxFromClientX(e.clientX);
      applyIdx(idx, false);
      playLeverCreak(0.25, 'start');
    });

    track.addEventListener('touchstart', e => {
      dragging = true;
      const idx = idxFromClientX(e.touches[0].clientX);
      applyIdx(idx, false);
      playLeverCreak(0.25, 'start');
    }, { passive: true });

    document.addEventListener('mousemove', e => {
      if (!dragging) return;
      const newIdx = idxFromClientX(e.clientX);
      if (newIdx !== currentSlotIdx) playLeverCreak(0.15, 'mid');
      applyIdx(newIdx, false);
    });

    document.addEventListener('touchmove', e => {
      if (!dragging) return;
      const newIdx = idxFromClientX(e.touches[0].clientX);
      if (newIdx !== currentSlotIdx) playLeverCreak(0.15, 'mid');
      applyIdx(newIdx, false);
    }, { passive: true });

    document.addEventListener('mouseup',  () => { if (dragging) { dragging = false; playLeverCreak(0.2, 'end'); } });
    document.addEventListener('touchend', () => { if (dragging) { dragging = false; playLeverCreak(0.2, 'end'); } });
  }


  /* ──────────────────────────────────────────────────────────
     F. WHEEL DRAWING
     drawWheel()     — clears and redraws all segments + hub
     buildFrameSVG() — generates the ornamental ring SVG injected
                       around the wheel
     drawHub()       — draws the mandala medallion at the centre
     MOTIFS[]        — 5 small decorative patterns drawn in segment
  ────────────────────────────────────────────────────────── */
  let wheelAngle = 0;

  /**
   * buildFrameSVG(wSize)
   * Returns an SVG string for the ornamental ring surrounding the wheel.
   * Injected into .wheel-door by initLayout().
   */
  function buildFrameSVG(wSize) {
    const pad  = wSize * 0.13;
    const tot  = wSize + pad * 2;
    const r    = wSize / 2;
    const cx   = tot / 2, cy = tot / 2;
    const spokes = [0,45,90,135,180,225,270,315].map(deg => {
      const a   = deg * Math.PI / 180;
      const ir  = r + 10, or1 = r + pad * .38, or2 = r + pad * .68;
      const sx  = cx + Math.cos(a)*ir, sy  = cy + Math.sin(a)*ir;
      const mx  = cx + Math.cos(a)*or1, my  = cy + Math.sin(a)*or1;
      const ex  = cx + Math.cos(a)*or2, ey  = cy + Math.sin(a)*or2;
      const d   = deg % 90 !== 0;
      return `<line x1="${sx.toFixed(1)}" y1="${sy.toFixed(1)}" x2="${mx.toFixed(1)}" y2="${my.toFixed(1)}" stroke="#C9FF4B" stroke-width="${d?.8:1.2}" opacity="${d?.2:.35}"/>
              <line x1="${mx.toFixed(1)}" y1="${my.toFixed(1)}" x2="${ex.toFixed(1)}" y2="${ey.toFixed(1)}" stroke="#C9FF4B" stroke-width="${d?.5:.8}"  opacity="${d?.12:.2}"/>`;
    }).join('');
    const diamonds = [0,90,180,270].map(deg => {
      const a  = deg * Math.PI / 180, d = r + pad * .52, ds = 5.5;
      const px = cx + Math.cos(a)*d, py = cy + Math.sin(a)*d;
      return `<polygon points="${px},${py-ds} ${px+ds},${py} ${px},${py+ds} ${px-ds},${py}" stroke="#C9FF4B" stroke-width="1" fill="none" opacity="0.45"/>
              <circle cx="${px}" cy="${py}" r="1.8" fill="#C9FF4B" opacity="0.55"/>`;
    }).join('');
    const fleurs = [45,135,225,315].map(deg => {
      const a  = deg * Math.PI / 180, d = r + pad * .52;
      const px = cx + Math.cos(a)*d, py = cy + Math.sin(a)*d;
      return `<circle cx="${px.toFixed(1)}" cy="${py.toFixed(1)}" r="3.5" stroke="#C9FF4B" stroke-width="0.9" fill="none" opacity="0.3"/>
              <circle cx="${px.toFixed(1)}" cy="${py.toFixed(1)}" r="1.3" fill="#C9FF4B" opacity="0.35"/>`;
    }).join('');
    return `<svg class="frame-svg" style="position:absolute;top:${-pad}px;left:${-pad}px;width:${tot}px;height:${tot}px;" viewBox="0 0 ${tot} ${tot}" fill="none" aria-hidden="true">
      <circle cx="${cx}" cy="${cy}" r="${r+pad*.72}" stroke="#C9FF4B" stroke-width="1.4" opacity="0.38"/>
      <circle cx="${cx}" cy="${cy}" r="${r+6}"       stroke="#C9FF4B" stroke-width="0.7" opacity="0.22"/>
      <circle cx="${cx}" cy="${cy}" r="${r+pad*.45}" stroke="#C9FF4B" stroke-width="0.6" stroke-dasharray="4 8" opacity="0.28"/>
      ${spokes}${diamonds}${fleurs}
    </svg>`;
  }

  /**
   * hubBloom: 0 → 1 progress driven by startHubBloom().
   *
   * Easing: custom "bloom curve" — starts near-still (like a bud),
   * accelerates through the middle (petals opening), then gracefully
   * decelerates as each layer settles into place.
   *   t 0.0 → 0.3  : near-zero progress  (bud holds)
   *   t 0.3 → 0.7  : fast unfurl          (bloom burst)
   *   t 0.7 → 1.0  : slow settle          (petals find rest)
   */
  let hubBloom = 0;

  function bloomEase(t) {
    if (t < 0.15) return Math.pow(t / 0.15, 2.2) * 0.12;           // brief bud hold
    if (t < 0.65) return 0.12 + Math.pow((t - 0.15) / 0.5, 0.65) * 0.75; // bloom burst
    return 0.87 + Math.pow((t - 0.65) / 0.35, 1.6) * 0.13;          // settle
  }

  function startHubBloom() {
    hubBloom = 0;
    const start    = performance.now();
    const duration = 4000; // 4 s — snappier start, still graceful finish

    (function tick(now) {
      const t = Math.min(1, (now - start) / duration);
      hubBloom = bloomEase(t);
      drawWheel();
      if (t < 1) requestAnimationFrame(tick);
      else        hubBloom = 1;
    })(start);
  }

  /**
   * drawHub(ctx, cx, cy, R)
   *
   * Layered folk-embroidery medallion with bloom animation.
   * Layer order (back → front):
   *   1. Background glow disc
   *   2. Dark outer rim + beaded rings
   *   3. 8 outer pointed leaf-tips (outermost ring)
   *   4. 4 large drooping side-leaf pairs
   *   5. 4 tall tulip petals (red, cardinal axes)
   *   6. 4 round cream guard petals (diagonal axes)
   *   7. 8 small stem-leaf buds at mid-ring
   *   8. Dark scallop separation ring
   *   9. 6-petal inner rosette (alternating red / cream / sage)
   *  10. 5 small stamens around centre
   *  11. Central flower disc (gold radial gradient)
   *  12. Bright stamen core dot
   */
  function drawHub(ctx, cx, cy, R) {
    const b = hubBloom;
    if (b <= 0) return;
    ctx.save();
    ctx.translate(cx, cy);

    // ph(enter, speed) — returns 0→1 progress for this layer.
    // enter: when in the bloom (0=first, 1=last)
    // speed: how quickly the layer reaches full opacity once it starts (lower = slower unfurl)
    // With the new bloom curve the effective real-time spread across 5s is:
    //   enter 0.0 → starts ~0.5s  |  enter 0.8 → starts ~4.0s
    const ph = (enter, speed = 2.0) => Math.min(1, Math.max(0, (b - enter) * speed));

    // ── Background ──────────────────────────────────────────────
    const bgG = ctx.createRadialGradient(0,0,0, 0,0,R);
    bgG.addColorStop(0, '#1a2800'); bgG.addColorStop(0.65, '#0c1400'); bgG.addColorStop(1, 'rgba(0,8,0,0)');
    ctx.beginPath(); ctx.arc(0,0,R,0,Math.PI*2);
    ctx.fillStyle=bgG; ctx.globalAlpha=Math.min(1,b*3); ctx.fill(); ctx.globalAlpha=1;

    // ── Dark base disc ───────────────────────────────────────────
    ctx.beginPath(); ctx.arc(0,0,R*.97,0,Math.PI*2);
    ctx.fillStyle='#080c00'; ctx.fill();

    // ── Outer beaded ring — appears early, slowly ─────────────────
    const beadB = ph(0, 1.8);
    for (let i=0; i<56; i++) {
      const a = i*Math.PI/28, d = R*.92;
      ctx.beginPath(); ctx.arc(Math.cos(a)*d, Math.sin(a)*d, 1.5, 0, Math.PI*2);
      const bright = i%4===0;
      ctx.fillStyle = bright ? '#C9FF4B' : 'rgba(180,220,50,0.4)';
      ctx.globalAlpha = beadB * (bright ? 0.9 : 0.5); ctx.fill(); ctx.globalAlpha=1;
    }
    // Outer ring stroke
    ctx.strokeStyle='rgba(201,255,75,0.5)'; ctx.lineWidth=2;
    ctx.globalAlpha=beadB; ctx.beginPath(); ctx.arc(0,0,R*.88,0,Math.PI*2); ctx.stroke(); ctx.globalAlpha=1;

    // ══ LAYER 1: 8 outer leaf-fans ═══════════════════════════════
    // Each fan: 3 radiating teardrop leaves like an embroidered fleur cluster
    for (let i=0; i<8; i++) {
      const lph = Math.min(1, Math.max(0, ph(0.05, 1.8) - i*0.025));
      if (lph<=0) continue;
      ctx.save(); ctx.rotate(i*Math.PI/4); ctx.globalAlpha=lph;
      // Centre leaf — tall
      ctx.beginPath();
      ctx.moveTo(0, -R*.60);
      ctx.bezierCurveTo( R*.10,-R*.70,  R*.08,-R*.86,  0,     -R*.90);
      ctx.bezierCurveTo(-R*.08,-R*.86, -R*.10,-R*.70,  0,     -R*.60);
      ctx.closePath();
      ctx.fillStyle = i%2===0 ? '#3d7008' : '#2d5505';
      ctx.fill(); ctx.strokeStyle='rgba(160,220,40,0.6)'; ctx.lineWidth=1; ctx.stroke();
      // Left side leaf
      ctx.beginPath();
      ctx.moveTo(-R*.06,-R*.60);
      ctx.bezierCurveTo(-R*.22,-R*.65, -R*.30,-R*.76, -R*.24,-R*.82);
      ctx.bezierCurveTo(-R*.16,-R*.88, -R*.06,-R*.78, -R*.06,-R*.60);
      ctx.closePath();
      ctx.fillStyle='rgba(100,170,30,0.75)'; ctx.fill();
      ctx.strokeStyle='rgba(140,200,30,0.4)'; ctx.lineWidth=0.7; ctx.stroke();
      // Right side leaf
      ctx.beginPath();
      ctx.moveTo( R*.06,-R*.60);
      ctx.bezierCurveTo( R*.22,-R*.65,  R*.30,-R*.76,  R*.24,-R*.82);
      ctx.bezierCurveTo( R*.16,-R*.88,  R*.06,-R*.78,  R*.06,-R*.60);
      ctx.closePath();
      ctx.fillStyle='rgba(120,190,35,0.7)'; ctx.fill();
      ctx.strokeStyle='rgba(140,200,30,0.4)'; ctx.lineWidth=0.7; ctx.stroke();
      // Tip berry
      ctx.beginPath(); ctx.arc(0,-R*.89,R*.024,0,Math.PI*2);
      ctx.fillStyle='rgba(220,255,80,0.8)'; ctx.fill();
      ctx.restore();
    }

    // ══ LAYER 2: 4 large round rose petals (cardinal) ════════════
    for (let i=0; i<4; i++) {
      const lph = Math.min(1, Math.max(0, ph(0.18, 1.6) - i*0.035));
      if (lph<=0) continue;
      // Petals scale up from the hub centre — true bloom feel
      const sc = Math.pow(lph, 0.6); // fast initial scale, slow finish
      ctx.save(); ctx.rotate(i*Math.PI/2); ctx.scale(sc, sc); ctx.globalAlpha=lph;
      // Big rounded teardrop — the heart of the embroidery
      ctx.beginPath();
      ctx.moveTo(0, -R*.28);
      ctx.bezierCurveTo( R*.44,-R*.30,  R*.50,-R*.52,  R*.30,-R*.62);
      ctx.bezierCurveTo( R*.18,-R*.68,  R*.08,-R*.72,  0,    -R*.74);
      ctx.bezierCurveTo(-R*.08,-R*.72, -R*.18,-R*.68, -R*.30,-R*.62);
      ctx.bezierCurveTo(-R*.50,-R*.52, -R*.44,-R*.30,  0,    -R*.28);
      ctx.closePath();
      const rG = ctx.createLinearGradient(0,-R*.28, 0,-R*.74);
      rG.addColorStop(0,   '#C82000');
      rG.addColorStop(0.45,'#DD2800');
      rG.addColorStop(0.8, '#E84500');
      rG.addColorStop(1,   '#F06020');
      ctx.fillStyle=rG; ctx.fill();
      ctx.strokeStyle='rgba(255,140,60,0.7)'; ctx.lineWidth=1.4; ctx.stroke();
      // Inner petal detail — lighter centre stripe
      ctx.beginPath();
      ctx.moveTo(0,-R*.32);
      ctx.bezierCurveTo( R*.12,-R*.45,  R*.10,-R*.60,  0,-R*.68);
      ctx.bezierCurveTo(-R*.10,-R*.60, -R*.12,-R*.45,  0,-R*.32);
      ctx.closePath();
      ctx.fillStyle='rgba(255,110,40,0.28)'; ctx.fill();
      // 3 tip lobes
      [[-R*.25,-R*.60],[0,-R*.72],[R*.25,-R*.60]].forEach(([ox,oy])=>{
        ctx.beginPath(); ctx.arc(ox,oy,R*.028,0,Math.PI*2);
        ctx.fillStyle='rgba(255,200,80,0.85)'; ctx.fill();
      });
      ctx.restore();
    }

    // ══ LAYER 3: 4 cream fan petals (diagonal) ════════════════════
    for (let i=0; i<4; i++) {
      const lph = Math.min(1, Math.max(0, ph(0.28, 1.8) - i*0.03));
      if (lph<=0) continue;
      const sc = Math.pow(lph, 0.6);
      ctx.save(); ctx.rotate(i*Math.PI/2 + Math.PI/4); ctx.scale(sc, sc); ctx.globalAlpha=lph;
      // Round egg-shaped petal
      ctx.beginPath();
      ctx.moveTo(0,-R*.30);
      ctx.bezierCurveTo( R*.28,-R*.34,  R*.32,-R*.50,  R*.20,-R*.58);
      ctx.bezierCurveTo( R*.10,-R*.64,  R*.04,-R*.66,  0,    -R*.66);
      ctx.bezierCurveTo(-R*.04,-R*.66, -R*.10,-R*.64, -R*.20,-R*.58);
      ctx.bezierCurveTo(-R*.32,-R*.50, -R*.28,-R*.34,  0,    -R*.30);
      ctx.closePath();
      ctx.fillStyle='rgba(245,248,205,0.92)'; ctx.fill();
      ctx.strokeStyle='rgba(170,155,45,0.6)'; ctx.lineWidth=1; ctx.stroke();
      // Vein
      ctx.beginPath(); ctx.moveTo(0,-R*.33); ctx.lineTo(0,-R*.64);
      ctx.strokeStyle='rgba(100,130,20,0.4)'; ctx.lineWidth=0.8; ctx.stroke();
      // Tip dot
      ctx.beginPath(); ctx.arc(0,-R*.64,R*.022,0,Math.PI*2);
      ctx.fillStyle='rgba(180,215,60,0.8)'; ctx.fill();
      ctx.restore();
    }

    // ══ LAYER 4: 8 mid-ring teardrop buds ═════════════════════════
    for (let i=0; i<8; i++) {
      const lph = Math.min(1, Math.max(0, ph(0.42, 2.0) - i*0.022));
      if (lph<=0) continue;
      ctx.save(); ctx.rotate(i*Math.PI/4 + Math.PI/8); ctx.scale(lph, lph); ctx.globalAlpha=lph;
      ctx.beginPath();
      ctx.moveTo(0,-R*.42);
      ctx.bezierCurveTo( R*.10,-R*.46,  R*.09,-R*.55,  0,-R*.56);
      ctx.bezierCurveTo(-R*.09,-R*.55, -R*.10,-R*.46,  0,-R*.42);
      ctx.closePath();
      const budCol = [
        '#3d7008','rgba(245,248,200,0.85)','#C82000','rgba(245,248,200,0.85)',
        '#3d7008','rgba(245,248,200,0.85)','#C82000','rgba(245,248,200,0.85)',
      ][i];
      ctx.fillStyle=budCol; ctx.fill();
      ctx.strokeStyle='rgba(180,160,40,0.45)'; ctx.lineWidth=0.7; ctx.stroke();
      ctx.restore();
    }

    // ══ LAYER 5: Dark scallop collar ring ═════════════════════════
    const collarB = ph(0.50, 2.2);
    if (collarB>0) {
      ctx.globalAlpha=collarB;
      ctx.beginPath(); ctx.arc(0,0,R*.37,0,Math.PI*2);
      ctx.fillStyle='#080d00'; ctx.fill();
      ctx.strokeStyle='rgba(201,175,55,0.9)'; ctx.lineWidth=1.8; ctx.stroke();
      // 12 scallop bumps
      for (let i=0; i<12; i++) {
        const a = i*Math.PI/6;
        ctx.beginPath(); ctx.arc(Math.cos(a)*R*.37, Math.sin(a)*R*.37, R*.05, 0, Math.PI*2);
        ctx.fillStyle='#080d00'; ctx.fill();
        ctx.strokeStyle='rgba(201,175,55,0.55)'; ctx.lineWidth=0.8; ctx.stroke();
      }
      // 4 cardinal red gems on collar
      for (let i=0; i<4; i++) {
        const a = i*Math.PI/2;
        ctx.beginPath(); ctx.arc(Math.cos(a)*R*.37, Math.sin(a)*R*.37, R*.040, 0, Math.PI*2);
        const gG = ctx.createRadialGradient(
          Math.cos(a)*R*.37-R*.010, Math.sin(a)*R*.37-R*.010, 0,
          Math.cos(a)*R*.37, Math.sin(a)*R*.37, R*.040
        );
        gG.addColorStop(0,'#FF5020'); gG.addColorStop(1,'#880800');
        ctx.fillStyle=gG; ctx.fill();
        ctx.strokeStyle='rgba(255,160,60,0.7)'; ctx.lineWidth=0.9; ctx.stroke();
      }
      ctx.globalAlpha=1;
    }

    // ══ LAYER 6: Inner 8-petal open daisy ═════════════════════════
    const innerB = ph(0.57, 2.0);
    for (let i=0; i<8; i++) {
      const lph = Math.min(1, Math.max(0, innerB - i*0.025));
      if (lph<=0) continue;
      const sc = Math.pow(lph, 0.55);
      ctx.save(); ctx.rotate(i*Math.PI/4 - Math.PI/8); ctx.scale(sc, sc); ctx.globalAlpha=lph;
      ctx.beginPath();
      ctx.moveTo(0,-R*.09);
      ctx.bezierCurveTo( R*.14,-R*.12,  R*.16,-R*.24,  0,-R*.28);
      ctx.bezierCurveTo(-R*.16,-R*.24, -R*.14,-R*.12,  0,-R*.09);
      ctx.closePath();
      const daisyCols=['#CC2000','#DDE8A0','#CC2000','#DDE8A0',
                       '#5a8810','#DDE8A0','#5a8810','#DDE8A0'];
      ctx.fillStyle=daisyCols[i]; ctx.fill();
      ctx.strokeStyle='rgba(200,180,50,0.65)'; ctx.lineWidth=0.8; ctx.stroke();
      ctx.restore();
    }

    // ══ LAYER 7: Centre flower disc ═══════════════════════════════
    const centreB = ph(0.65, 2.5);
    if (centreB>0) {
      const sc = Math.pow(centreB, 0.5); // pops open quickly once it starts
      ctx.globalAlpha=centreB; ctx.save(); ctx.scale(sc, sc);
      // Sage-green outer disc ring
      ctx.beginPath(); ctx.arc(0,0,R*.155,0,Math.PI*2);
      ctx.fillStyle='#4a7010'; ctx.fill();
      ctx.strokeStyle='rgba(200,180,50,0.9)'; ctx.lineWidth=1.4; ctx.stroke();
      // Cream middle
      const cm = ctx.createRadialGradient(0,0,0, 0,0,R*.10);
      cm.addColorStop(0,  'rgba(255,245,200,1)');
      cm.addColorStop(0.5,'rgba(245,220,150,0.95)');
      cm.addColorStop(1,  'rgba(200,165,70,0.85)');
      ctx.beginPath(); ctx.arc(0,0,R*.10,0,Math.PI*2);
      ctx.fillStyle=cm; ctx.fill();
      ctx.strokeStyle='rgba(201,175,55,0.9)'; ctx.lineWidth=1.1; ctx.stroke();
      ctx.restore(); ctx.globalAlpha=1;
    }

    // 6 small orange-red centre petals
    const cpB = ph(0.72, 2.8);
    for (let i=0; i<6; i++) {
      const lph = Math.min(1, Math.max(0, cpB - i*0.02));
      if (lph<=0) continue;
      const a = i*Math.PI/3;
      ctx.save(); ctx.rotate(a); ctx.scale(lph, lph); ctx.globalAlpha=lph;
      ctx.beginPath(); ctx.ellipse(0,-R*.075, R*.030, R*.045, 0, 0, Math.PI*2);
      const pG = ctx.createRadialGradient(0,-R*.07,0, 0,-R*.075,R*.045);
      pG.addColorStop(0,'#FF6020'); pG.addColorStop(1,'#CC1000');
      ctx.fillStyle=pG; ctx.fill();
      ctx.strokeStyle='rgba(255,180,60,0.7)'; ctx.lineWidth=0.7; ctx.stroke();
      ctx.restore();
    }

    // ══ LAYER 8: Bright stamen core ════════════════════════════════
    const coreB = ph(0.82, 3.5);
    if (coreB>0) {
      ctx.globalAlpha=coreB;
      // Outer glow
      const og = ctx.createRadialGradient(0,0,0, 0,0,R*.058);
      og.addColorStop(0,'rgba(255,250,200,1)'); og.addColorStop(0.6,'rgba(255,215,80,0.9)'); og.addColorStop(1,'rgba(200,150,20,0.6)');
      ctx.beginPath(); ctx.arc(0,0,R*.058,0,Math.PI*2);
      ctx.fillStyle=og; ctx.fill();
      ctx.strokeStyle='rgba(220,185,55,1)'; ctx.lineWidth=1.2; ctx.stroke();
      // Inner coral pip
      ctx.beginPath(); ctx.arc(0,0,R*.028,0,Math.PI*2);
      ctx.fillStyle='#CC2A00'; ctx.fill();
      // Specular
      ctx.beginPath(); ctx.arc(-R*.016,-R*.016,R*.013,0,Math.PI*2);
      ctx.fillStyle='rgba(255,255,230,0.75)'; ctx.fill();
      ctx.globalAlpha=1;
    }

    ctx.restore();
  }

  /** Small decorative icons stamped into each wheel segment */
  const MOTIFS = [
    (c,x,y,r) => { c.save();c.translate(x,y);c.strokeStyle='rgba(0,0,0,.18)';c.lineWidth=.7;for(let i=0;i<8;i++){const a=i*Math.PI/4;c.beginPath();c.moveTo(Math.cos(a)*r*.3,Math.sin(a)*r*.3);c.lineTo(Math.cos(a)*r*.72,Math.sin(a)*r*.72);c.stroke();}c.beginPath();c.arc(0,0,r*.28,0,Math.PI*2);c.stroke();c.restore(); },
    (c,x,y,r) => { c.save();c.translate(x,y);c.fillStyle='rgba(0,0,0,.15)';c.fillRect(-r*.08,-r*.44,r*.16,r*.88);c.fillRect(-r*.44,-r*.09,r*.88,r*.18);c.restore(); },
    (c,x,y,r) => { c.save();c.translate(x,y);c.fillStyle='rgba(0,0,0,.18)';const p=[];for(let i=0;i<5;i++){const a=i*Math.PI*2/5-Math.PI/2;p.push([Math.cos(a)*r*.48,Math.sin(a)*r*.48]);const a2=a+Math.PI/5;p.push([Math.cos(a2)*r*.19,Math.sin(a2)*r*.19]);}c.beginPath();p.forEach(([px,py],i)=>i?c.lineTo(px,py):c.moveTo(px,py));c.closePath();c.fill();c.restore(); },
    (c,x,y,r) => { c.save();c.translate(x,y);c.strokeStyle='rgba(0,0,0,.18)';c.lineWidth=.7;c.beginPath();c.moveTo(0,-r*.47);c.lineTo(r*.33,0);c.lineTo(0,r*.47);c.lineTo(-r*.33,0);c.closePath();c.stroke();c.restore(); },
    (c,x,y,r) => { c.save();c.translate(x,y);c.fillStyle='rgba(0,0,0,.15)';c.beginPath();c.arc(0,-r*.25,r*.18,0,Math.PI*2);c.fill();c.beginPath();c.arc(-r*.2,r*.08,r*.12,0,Math.PI*2);c.fill();c.beginPath();c.arc(r*.2,r*.08,r*.12,0,Math.PI*2);c.fill();c.restore(); },
  ];

  function drawWheel() {
    const cv  = document.getElementById('wheel');
    const ctx = cv.getContext('2d');
    const S = 800, c = 400, r = 390;
    ctx.clearRect(0, 0, S, S);

    const quests      = QUEST_DATA[currentSlot] || QUEST_DATA['5'];
    const customLabels = customWheelItems.filter(x => !quests.find(q => q.label === x));
    const allQuests   = [...quests, ...customLabels.map(l => ({ label: l, cat: 'misc' }))];
    const n           = allQuests.length;
    const arc         = Math.PI * 2 / n;

    for (let i = 0; i < n; i++) {
      const q   = allQuests[i];
      const s   = wheelAngle + i * arc;
      const e   = s + arc;
      const bg  = getSegColor(q, i);
      const mid = s + arc / 2;

      // Segment fill + stroke
      ctx.beginPath(); ctx.moveTo(c, c); ctx.arc(c, c, r, s, e); ctx.closePath();
      ctx.fillStyle = bg; ctx.fill();
      ctx.strokeStyle = 'rgba(201,255,75,.12)'; ctx.lineWidth = 1; ctx.stroke();

      // Decorative motif in mid-segment
      MOTIFS[i % MOTIFS.length](ctx, c + Math.cos(mid)*r*.59, c + Math.sin(mid)*r*.59, r*.08);

      // Category micro-label + main quest label
      ctx.save();
      ctx.translate(c, c); ctx.rotate(mid); ctx.textAlign = 'right';

      // Tiny category badge
      ctx.font = '6px Courier Prime, monospace'; ctx.fillStyle = textForBg(bg); ctx.globalAlpha = 0.5;
      ctx.fillText(q.cat.toUpperCase(), r - 28, -4);
      ctx.globalAlpha = 1;

      // Main label — auto-shrink to fit available segment width
      const availW  = r - 70;
      const label   = q.label.length > 28 ? q.label.slice(0, 28) + '…' : q.label;
      let fs        = Math.max(7.5, Math.min(12, 230 / n));
      ctx.font      = `${fs}px 'Courier Prime', monospace`;
      while (ctx.measureText(label).width > availW && fs > 6.5) {
        fs -= 0.4;
        ctx.font = `${fs}px 'Courier Prime', monospace`;
      }
      ctx.fillStyle = textForBg(bg);
      ctx.shadowColor = 'rgba(0,0,0,.4)'; ctx.shadowBlur = 4;
      ctx.fillText(label, r - 28, fs * .38 + 6);
      ctx.restore();
    }

    // Rim ticks + outer ring
    for (let i = 0; i < n; i++) {
      const a = wheelAngle + i * arc;
      ctx.beginPath();
      ctx.moveTo(c + Math.cos(a)*(r-3), c + Math.sin(a)*(r-3));
      ctx.lineTo(c + Math.cos(a)*(r+2), c + Math.sin(a)*(r+2));
      ctx.strokeStyle = 'rgba(201,255,75,.28)'; ctx.lineWidth = .9; ctx.stroke();
    }
    ctx.beginPath(); ctx.arc(c,c,r+1.5,0,Math.PI*2);
    ctx.strokeStyle = 'rgba(201,255,75,.55)'; ctx.lineWidth = 2.5; ctx.stroke();

    // Mandala hub — R=155 for dominant presence
    drawHub(ctx, c, c, 155);
  }


  /* ──────────────────────────────────────────────────────────
     G. ARC LEVER
     Quarter-arc (−90° → 0°) sits in the top-right quadrant of
     the wheel.  The groove SVG is generated and injected into
     .lever-arc-wrap by buildLever().  Drag the knob clockwise
     to accumulate sweep; release triggers spinWheel().
     The knob springs back to 12 o'clock after release.
  ────────────────────────────────────────────────────────── */
  const ARC_START = -Math.PI / 2;   // 12 o'clock
  const ARC_END   =  0;             //  3 o'clock

  let leverAngle       = ARC_START;
  let leverDragging    = false;
  let accumulatedSweep = 0;
  let lastLeverAngle   = leverAngle;
  let lastLeverSoundTime = 0;

  function buildLever() {
    const stage  = document.getElementById('wheelStage');
    const wSize  = stage.offsetWidth;
    const wheelCX = wSize / 2, wheelCY = wSize / 2;
    const arcR   = wSize / 2 + 22;     // sits just outside the wheel rim

    // Build arc path (quarter circle, top-right)
    let trackD = '';
    for (let i = 0; i <= 40; i++) {
      const a = ARC_START + (ARC_END - ARC_START) * i / 40;
      trackD += (i === 0 ? 'M' : 'L') + (wheelCX + Math.cos(a)*arcR).toFixed(1) + ' ' + (wheelCY + Math.sin(a)*arcR).toFixed(1) + ' ';
    }

    // Tick marks at start, mid, end
    const ticks = [ARC_START, (ARC_START+ARC_END)/2, ARC_END].map(a => {
      const ir = arcR - 8, or = arcR + 8;
      return `<line x1="${(wheelCX+Math.cos(a)*ir).toFixed(1)}" y1="${(wheelCY+Math.sin(a)*ir).toFixed(1)}"
                   x2="${(wheelCX+Math.cos(a)*or).toFixed(1)}" y2="${(wheelCY+Math.sin(a)*or).toFixed(1)}"
                   stroke="#C9FF4B" stroke-width="1.4" opacity="0.5"/>`;
    }).join('');

    // PULL label
    const lA = ARC_START - 0.18;
    const lx = (wheelCX + Math.cos(lA) * (arcR + 20)).toFixed(1);
    const ly = (wheelCY + Math.sin(lA) * (arcR + 20)).toFixed(1);

    document.getElementById('leverArcWrap').innerHTML = `
      <svg id="leverSVG" width="${wSize}" height="${wSize}"
           viewBox="0 0 ${wSize} ${wSize}"
           style="position:absolute;inset:0;width:100%;height:100%;overflow:visible;pointer-events:all;"
           xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="trkGrad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%"   stop-color="#1a2800"/>
            <stop offset="40%"  stop-color="#5a9008"/>
            <stop offset="60%"  stop-color="#7ac018"/>
            <stop offset="100%" stop-color="#1a2800"/>
          </linearGradient>
          <radialGradient id="knobG" cx="35%" cy="30%">
            <stop offset="0%"   stop-color="#e8ffc0"/>
            <stop offset="35%"  stop-color="#C9FF4B"/>
            <stop offset="70%"  stop-color="#6aaa10"/>
            <stop offset="100%" stop-color="#2a5000"/>
          </radialGradient>
          <filter id="kGlow" x="-50%" y="-50%" width="200%" height="200%">
            <feGaussianBlur stdDeviation="4" result="b"/>
            <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
          </filter>
        </defs>
        <!-- Track layers: shadow → body → groove → edge glow -->
        <path d="${trackD}" stroke="#060f00"              stroke-width="18" fill="none" stroke-linecap="round"/>
        <path d="${trackD}" stroke="url(#trkGrad)"        stroke-width="12" fill="none" stroke-linecap="round"/>
        <path d="${trackD}" stroke="rgba(0,0,0,0.6)"      stroke-width="6"  fill="none" stroke-linecap="round"/>
        <path d="${trackD}" stroke="rgba(201,255,75,0.25)" stroke-width="14" fill="none" stroke-linecap="round"/>
        ${ticks}
        <!-- Knob — translated into position by positionKnob() -->
        <g id="leverKnob" style="cursor:grab;">
          <circle cx="0" cy="0" r="18" fill="url(#knobG)" filter="url(#kGlow)"/>
          <ellipse cx="-4" cy="-5" rx="7" ry="5" fill="rgba(255,255,255,0.6)" opacity="0.7"/>
          <circle cx="0" cy="0" r="18" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1.2"/>
          <circle cx="0" cy="0" r="15" fill="none" stroke="rgba(0,0,0,0.28)"     stroke-width="0.8"/>
          <circle cx="0" cy="0" r="4"  fill="rgba(0,0,0,0.2)"/>
          <circle cx="0" cy="0" r="2.2" fill="rgba(255,255,255,0.4)"/>
          <line x1="-9" y1="0" x2="9" y2="0" stroke="rgba(0,0,0,0.18)" stroke-width="1.1"/>
          <line x1="0" y1="-9" x2="0" y2="9" stroke="rgba(0,0,0,0.18)" stroke-width="1.1"/>
        </g>
      </svg>`;

    positionKnob();
    setupLeverEvents(wheelCX, wheelCY, arcR);
  }

  function positionKnob() {
    const stage = document.getElementById('wheelStage');
    const sz    = stage.offsetWidth;
    const cx    = sz / 2, cy = sz / 2, aR = sz / 2 + 22;
    const knob  = document.getElementById('leverKnob');
    if (!knob) return;
    knob.setAttribute('transform', `translate(${(cx + Math.cos(leverAngle)*aR).toFixed(1)},${(cy + Math.sin(leverAngle)*aR).toFixed(1)})`);
  }

  function setupLeverEvents(arcCX, arcCY, arcR) {
    const svg = document.getElementById('leverSVG');
    if (!svg) return;

    function toSVG(clientX, clientY) {
      const rect = svg.getBoundingClientRect();
      const scX  = parseFloat(svg.getAttribute('width'))  / (rect.width  || 1);
      const scY  = parseFloat(svg.getAttribute('height')) / (rect.height || 1);
      return { x: (clientX - rect.left) * scX, y: (clientY - rect.top) * scY };
    }

    function angleFrom(clientX, clientY) {
      const p = toSVG(clientX, clientY);
      return Math.atan2(p.y - arcCY, p.x - arcCX);
    }

    function clamp(a) { return Math.max(ARC_START, Math.min(ARC_END, a)); }

    function onStart(e) {
      const cx = e.touches ? e.touches[0].clientX : e.clientX;
      const cy = e.touches ? e.touches[0].clientY : e.clientY;
      const p  = toSVG(cx, cy);
      if (Math.abs(Math.sqrt((p.x-arcCX)**2 + (p.y-arcCY)**2) - arcR) > 45) return;
      e.preventDefault();
      leverDragging    = true;
      accumulatedSweep = 0;
      const a = clamp(angleFrom(cx, cy));
      leverAngle = lastLeverAngle = a;
      positionKnob();
      const k = document.getElementById('leverKnob');
      if (k) k.style.cursor = 'grabbing';
      playLeverCreak(0.3, 'start');
      document.addEventListener('mousemove', onMove, { passive: false });
      document.addEventListener('mouseup',   onEnd);
      document.addEventListener('touchmove', onMove, { passive: false });
      document.addEventListener('touchend',  onEnd);
    }

    function onMove(e) {
      if (!leverDragging) return;
      e.preventDefault();
      const cx = e.touches ? e.touches[0].clientX : e.clientX;
      const cy = e.touches ? e.touches[0].clientY : e.clientY;
      const a  = clamp(angleFrom(cx, cy));
      const d  = a - lastLeverAngle;
      accumulatedSweep += Math.abs(d);
      lastLeverAngle = leverAngle = a;
      positionKnob();
      const now = Date.now();
      if (Math.abs(d) > 0.01 && now - lastLeverSoundTime > 65) {
        playLeverCreak(Math.min(1, Math.abs(d) * 15), 'mid');
        lastLeverSoundTime = now;
      }
      if (!spinning) { wheelAngle += d * 0.1; drawWheel(); }
    }

    function onEnd() {
      if (!leverDragging) return;
      leverDragging = false;
      const k = document.getElementById('leverKnob');
      if (k) k.style.cursor = 'grab';
      document.removeEventListener('mousemove', onMove);
      document.removeEventListener('mouseup',   onEnd);
      document.removeEventListener('touchmove', onMove);
      document.removeEventListener('touchend',  onEnd);
      playLeverCreak(Math.min(1, accumulatedSweep * 2), 'end');

      // Spring back to top (ARC_START)
      const from = leverAngle;
      let prog   = 0;
      (function spring() {
        prog      = Math.min(prog + 0.04, 1);
        leverAngle = from + (ARC_START - from) * (1 - Math.pow(1 - prog, 3));
        positionKnob();
        if (prog < 1) requestAnimationFrame(spring);
        else leverAngle = ARC_START;
      })();

      if (accumulatedSweep > 0.15 && !spinning) spinWheel(Math.min(3, accumulatedSweep * 2.5));
    }

    svg.addEventListener('mousedown',  onStart);
    svg.addEventListener('touchstart', onStart, { passive: false });
  }


  /* ──────────────────────────────────────────────────────────
     H. SPIN MECHANICS
     Heavy-wheel physics:
       • Fast linear phase (0–60% of duration)
       • Long exponential brake (60–100%)
     Woody rolling sound fades at 88% to give clean separation
     before the sparkle/pamphlet reveal.
  ────────────────────────────────────────────────────────── */
  let spinning = false;

  /**
   * heavyEase(t)
   * Custom easing simulating angular momentum of a heavy wooden wheel.
   * @param {number} t  normalised time 0–1
   * @returns {number}  normalised progress 0–1
   */
  function heavyEase(t) {
    if (t < 0.6) return t * (1 / 0.6) * 0.75;          // fast linear phase
    return 0.75 + 0.25 * (1 - Math.pow(1 - (t - 0.6) / 0.4, 3.5)); // long brake
  }

  function spinWheel(forceMultiplier = 1) {
    if (spinning) return;
    spinning = true;
    startWoodyRoll(forceMultiplier);

    // Extra random arc offset injected before the spin so identical
    // lever pulls never land on the same segment twice in a row.
    const nudge    = Math.random() * Math.PI * 2;
    const rotations = 5 + Math.random() * 6 + forceMultiplier * 2;
    const extra     = Math.PI * 2 * rotations + nudge;
    const duration  = 3800 + forceMultiplier * 600 + Math.random() * 1400;
    const t0        = performance.now();
    const a0        = wheelAngle;
    let woodyFaded  = false;

    function frame(now) {
      const t = Math.min((now - t0) / duration, 1);
      wheelAngle = a0 + extra * heavyEase(t);
      drawWheel();

      // Fade wood sound slightly before stop for clean reveal
      if (!woodyFaded && t > 0.88) { woodyFaded = true; stopWoodyRoll(); }

      if (t < 1) {
        requestAnimationFrame(frame);
      } else {
        spinning = false;

        // Determine selected segment
        const quests     = QUEST_DATA[currentSlot] || QUEST_DATA['5'];
        const customLbls = customWheelItems.filter(x => !quests.find(q => q.label === x));
        const allQuests  = [...quests, ...customLbls.map(l => ({ label: l, cat: 'misc' }))];
        const n          = allQuests.length;
        const arc        = Math.PI * 2 / n;
        const norm       = ((wheelAngle % (Math.PI*2)) + Math.PI*2) % (Math.PI*2);
        const sel        = Math.floor(((Math.PI - norm + Math.PI*2) % (Math.PI*2)) / arc) % n;

        // Reveal with a small pause for audio separation
        setTimeout(() => {
          burstSparkles();
          playMagicalSparkle();
          spawnFX();
          openPamphlet(allQuests[sel]);
        }, 200);
      }
    }
    requestAnimationFrame(frame);
  }


  /* ──────────────────────────────────────────────────────────
     I. PAMPHLET MODAL
  ────────────────────────────────────────────────────────── */
  const CAT_DISPLAY_NAMES = {
    creative: 'Creative', movement: 'Movement',
    fermentation: 'Fermentation', outdoor: 'Outdoor', misc: 'Misc',
  };

  // Maps slot key → seconds for the timer
  const SLOT_SECONDS = { '5':300, '15':900, '30':1800, '60':3600, '2h':7200 };

  /**
   * openPamphlet(quest)
   * @param {object|string} quest  A QUEST_DATA entry or plain string label
   */
  function openPamphlet(quest) {
    const ov       = document.getElementById('pamphletOverlay');
    const qtEl     = document.getElementById('pamphletQuestText');
    const quillEl  = document.getElementById('pamphletQuill');
    const catEl    = document.getElementById('pamphletCategory');
    const iconEl   = document.getElementById('pamphletCatIcon');
    const themeEl  = document.getElementById('pamphletTheme');
    const sepEl    = document.getElementById('pamphletMetaSep');
    const extrasEl = document.getElementById('pamphletExtras');
    const timeEl   = document.getElementById('pamphletTime');
    const timerBtn = document.getElementById('pamphletTimerBtn');
    const sealEl   = document.getElementById('pamphletSealIcon');

    const isObj = typeof quest === 'object' && quest !== null;
    const label = isObj ? quest.label : quest;
    const cat   = isObj ? quest.cat : 'misc';
    const meta  = CAT_META[cat] || CAT_META.misc;

    // Reset animation state
    qtEl.textContent = label;
    qtEl.style.transition = 'none';
    qtEl.style.clipPath   = 'inset(0 100% 0 0)';
    quillEl.style.animation = 'none';
    quillEl.style.opacity   = '0';

    // Apply category accent to UI chrome only — quest text always stays legible white
    qtEl.style.color       = '#FCFFDD';
    qtEl.style.textShadow  = `0 0 24px ${meta.color}66, 0 0 60px ${meta.color}22`;
    if (sealEl) sealEl.style.color = meta.color;

    // Category icon + name
    if (iconEl) { iconEl.textContent = meta.icon + ' '; iconEl.style.color = meta.color; }
    if (catEl)  { catEl.textContent = CAT_DISPLAY_NAMES[cat] || cat; catEl.style.color = meta.color; catEl.style.textShadow = `0 0 16px ${meta.color}88`; }

    // Theme
    const theme = isObj ? (quest.theme || quest.body || quest.ingredients || '') : '';
    if (themeEl) { themeEl.textContent = theme; themeEl.style.color = meta.color; themeEl.style.textShadow = `0 0 14px ${meta.color}66`; }
    if (sepEl)   sepEl.style.display = theme ? 'inline' : 'none';

    // Time slot
    if (timeEl) timeEl.textContent = SLOT_NAMES[currentSlotIdx] || '';

    // Timer button label
    const slotLabel = SLOT_NAMES[currentSlotIdx] || '';
    if (timerBtn) timerBtn.textContent = `Start ${slotLabel.replace(/^[^ ]+ /,'')} timer`;

    // Extras
    if (extrasEl) {
      const parts = [];
      if (isObj) {
        if (quest.aesthetic && !quest.theme) parts.push(`aesthetic: ${quest.aesthetic}`);
        if (quest.steps)                    parts.push(quest.steps);
      }
      extrasEl.textContent = parts.join(' · ');
    }

    // Reset timer UI
    resetTimer(true);

    ov.classList.add('open');

    // Trigger ink-writing animation after scroll unrolls (~650ms)
    setTimeout(() => {
      qtEl.style.transition = 'clip-path 1.8s cubic-bezier(0.22,1,0.36,1)';
      qtEl.style.clipPath   = 'inset(0 0% 0 0)';
      quillEl.style.transition = 'opacity 0.2s';
      quillEl.style.opacity    = '1';
      quillEl.style.animation  = 'quillBlink 0.7s steps(1) 6';
    }, 650);

    spawnPamphletParticles();
  }

  function closePamphlet() {
    document.getElementById('pamphletOverlay').classList.remove('open');
    resetTimer(true);
  }

  function respinWheel() {
    closePamphlet();
    setTimeout(() => spinWheel(1.5), 300);
  }

  function spawnPamphletParticles() {
    const container = document.getElementById('pamphletParticles');
    if (!container) return;
    container.innerHTML = '';
    ['✦','✧','⁂','☽','✵','⚜','❧'].forEach((sym, i) => {
      const el = document.createElement('div');
      el.className = 'pp';
      el.textContent = sym;
      el.style.left   = 10 + Math.random() * 80 + '%';
      el.style.bottom = 10 + Math.random() * 60 + '%';
      el.style.animationDelay    = (0.8 + i * 0.3) + 's';
      el.style.animationDuration = (2 + Math.random() * 2) + 's';
      container.appendChild(el);
    });
  }


  /* ──────────────────────────────────────────────────────────
     I-b. COUNTDOWN TIMER
  ────────────────────────────────────────────────────────── */
  let timerTotal   = 0;
  let timerLeft    = 0;
  let timerRunning = false;
  let timerInterval= null;

  function formatTime(secs) {
    const h = Math.floor(secs / 3600);
    const m = Math.floor((secs % 3600) / 60);
    const s = secs % 60;
    if (h > 0) return `${h}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
    return `${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
  }

  function startPamphletTimer() {
    const secs = SLOT_SECONDS[currentSlot] || 300;
    timerTotal   = secs;
    timerLeft    = secs;
    timerRunning = true;
    const wrap = document.getElementById('timerWrap');
    const disp = document.getElementById('timerDisplay');
    const btn  = document.getElementById('timerPauseBtn');
    if (wrap) wrap.classList.add('visible');
    if (disp) { disp.classList.remove('done'); disp.textContent = formatTime(timerLeft); }
    if (btn)  btn.textContent = 'Pause';
    clearInterval(timerInterval);
    timerInterval = setInterval(() => {
      if (!timerRunning) return;
      timerLeft--;
      if (disp) disp.textContent = formatTime(timerLeft);
      if (timerLeft <= 0) {
        clearInterval(timerInterval);
        timerRunning = false;
        if (disp) disp.classList.add('done');
        playMagicalSparkle();
        burstSparkles();
        spawnFX();
        showToast('Time is up ✦');
        if (btn) btn.textContent = 'Done';
      }
    }, 1000);
  }

  function toggleTimer() {
    const btn = document.getElementById('timerPauseBtn');
    if (timerLeft <= 0) return;
    timerRunning = !timerRunning;
    if (btn) btn.textContent = timerRunning ? 'Pause' : 'Resume';
  }

  function resetTimer(silent = false) {
    clearInterval(timerInterval);
    timerRunning = false;
    timerLeft    = 0;
    const wrap = document.getElementById('timerWrap');
    const disp = document.getElementById('timerDisplay');
    const btn  = document.getElementById('timerPauseBtn');
    if (!silent) {
      if (wrap) wrap.classList.remove('visible');
    } else {
      if (wrap) wrap.classList.remove('visible');
    }
    if (disp) { disp.classList.remove('done'); disp.textContent = '00:00'; }
    if (btn)  btn.textContent = 'Pause';
  }


  /* ──────────────────────────────────────────────────────────
     J. ENVELOPE MODAL (Prompt generator)
     Currently unused in the main UI; retained for future use.
     Re-attach an entry point (button/shortcut) to expose it.
  ────────────────────────────────────────────────────────── */
  function openEnv() {
    const ov = document.getElementById('envOverlay');
    ['aesthetic','subject','medium'].forEach(k => {
      const el = document.getElementById('pval-' + k);
      if (el) el.innerHTML = '<span class="paper-empty-hint">draw to reveal…</span>';
    });
    document.getElementById('envFlap').classList.remove('opened');
    document.getElementById('envSeal').style.opacity = '1';
    document.getElementById('envDrawBtn').disabled = false;
    ov.classList.add('open');
    setTimeout(() => {
      document.getElementById('envFlap').classList.add('opened');
      setTimeout(() => document.getElementById('envSeal').style.opacity = '0', 300);
    }, 350);
  }

  function closeEnv() {
    document.getElementById('envFlap').classList.remove('opened');
    setTimeout(() => document.getElementById('envOverlay').classList.remove('open'), 300);
  }

  function overlayClick(e) {
    if (e.target === document.getElementById('envOverlay')) closeEnv();
  }

  function drawFromEnv() {
    const btn = document.getElementById('envDrawBtn');
    btn.disabled = true;
    const keys = ['aesthetic','subject','medium'];
    let tick = 0;
    const iv = setInterval(() => {
      keys.forEach(k => {
        const pool = POOLS[k];
        if (!pool.length) return;
        const pv = document.getElementById('pval-' + k);
        if (pv) { pv.textContent = pool[Math.floor(Math.random() * pool.length)]; pv.classList.add('shuffling'); }
      });
      if (++tick >= 10) {
        clearInterval(iv);
        btn.disabled = false;
        keys.forEach(k => {
          const pool = POOLS[k];
          if (!pool.length) return;
          const val = pool[Math.floor(Math.random() * pool.length)];
          const pv  = document.getElementById('pval-' + k);
          if (pv) { pv.textContent = val; pv.classList.remove('shuffling'); }
        });
        burstSparkles();
      }
    }, 80);
  }

  function renderPools() {
    ['aesthetic','subject','medium'].forEach(k => {
      const el = document.getElementById('ptags-' + k);
      if (!el) return;
      el.innerHTML = POOLS[k].map((v, i) =>
        `<div class="pool-tag" onclick="pinPool('${k}','${v.replace(/'/g,"\\'")}')">
           <span>${v}</span>
           <span class="tx" onclick="event.stopPropagation();rmPool('${k}',${i})">×</span>
         </div>`
      ).join('');
    });
  }

  function rmPool(k, i)  { POOLS[k].splice(i, 1); renderPools(); }
  function addPool(k)    { const el = document.getElementById('padd-' + k), v = el.value.trim(); if (!v || POOLS[k].includes(v)) { el.value=''; return; } POOLS[k].push(v); el.value=''; renderPools(); }
  function pinPool(k, v) { /* future: display pinned extras */ }


  /* ──────────────────────────────────────────────────────────
     K. UTILITY / FX
  ────────────────────────────────────────────────────────── */

  // Custom wheel items (user-added, persisted in memory only)
  let customWheelItems = [];

  /**
   * burstSparkles()
   * Fires a short burst of coloured 8-pointed stars across the viewport
   * using the sparkle canvas.
   */
  function burstSparkles() {
    const cv  = document.getElementById('sparkleCanvas');
    const ctx = cv.getContext('2d');
    const cols = ['#C9FF4B','#FCFFDD','#FF0004','#ffffff','#C9FF4B'];
    const burst = Array.from({ length: 35 }, () => ({
      x: Math.random() * cv.width,
      y: Math.random() * cv.height * .7,
      sz: 1 + Math.random() * 2.5,
      a: .9,
      dr: (Math.random() - .5) * 2,
      vy: -.9 - Math.random() * 1.5,
      col: cols[Math.floor(Math.random() * cols.length)],
    }));
    let fr = 0;
    (function animate() {
      burst.forEach(s => {
        s.x += s.dr; s.y += s.vy;
        s.a = Math.max(0, (1 - fr / 44) * .9);
        if (s.a > 0) {
          ctx.save(); ctx.globalAlpha = s.a; ctx.fillStyle = s.col; ctx.translate(s.x, s.y);
          ctx.beginPath();
          for (let i = 0; i < 8; i++) {
            const a = i * Math.PI / 4, rr = i % 2 === 0 ? s.sz * 4 : s.sz;
            i === 0 ? ctx.moveTo(Math.cos(a)*rr, Math.sin(a)*rr) : ctx.lineTo(Math.cos(a)*rr, Math.sin(a)*rr);
          }
          ctx.closePath(); ctx.fill(); ctx.restore();
        }
      });
      if (++fr < 44) requestAnimationFrame(animate);
    })();
  }

  /** spawnFX() — floats ornamental glyphs up the screen */
  function spawnFX() {
    ['✦','✧','⁂','❧','☀','☽','◆','✵'].forEach((c, i) => {
      setTimeout(() => {
        const el = document.createElement('div');
        el.className = 'fx-char';
        el.textContent = c;
        el.style.left = Math.random() * 88 + 'vw';
        el.style.top  = (28 + Math.random() * 48) + 'vh';
        document.body.appendChild(el);
        setTimeout(() => el.remove(), 2800);
      }, i * 55);
    });
  }

  /** showToast(msg) — brief status message at screen bottom */
  function showToast(msg) {
    const el = document.getElementById('toast');
    el.textContent = msg;
    el.classList.add('show');
    setTimeout(() => el.classList.remove('show'), 2700);
  }

  /** launchConfetti() — party-style confetti burst (unused in current UI) */
  function launchConfetti() {
    const cv  = document.getElementById('confettiCanvas');
    const ctx = cv.getContext('2d');
    cv.width = innerWidth; cv.height = innerHeight;
    const cols = ['#C9FF4B','#FF0004','#FCFFDD','#010D25'];
    const p = Array.from({ length: 65 }, () => ({
      x: Math.random() * cv.width, y: -8,
      r: 2.5 + Math.random() * 5,
      c: cols[Math.floor(Math.random() * cols.length)],
      vx: (Math.random() - .5) * 5,
      vy: 1.6 + Math.random() * 3.5,
      rot: Math.random() * Math.PI * 2,
      vr: (Math.random() - .5) * .13,
    }));
    let fr = 0;
    (function anim() {
      ctx.clearRect(0, 0, cv.width, cv.height);
      p.forEach(q => {
        q.x += q.vx; q.y += q.vy; q.rot += q.vr; q.vy += .07;
        ctx.save(); ctx.translate(q.x, q.y); ctx.rotate(q.rot);
        ctx.fillStyle = q.c; ctx.fillRect(-q.r/2, -q.r/2, q.r, q.r*1.6);
        ctx.restore();
      });
      if (++fr < 90) requestAnimationFrame(anim);
      else ctx.clearRect(0, 0, cv.width, cv.height);
    })();
  }


  /* ──────────────────────────────────────────────────────────
     L. INIT
     Called once on DOMContentLoaded / load.
     initTimeSlider() — wires up the snap slider
     initLayout()     — builds frame SVG + lever, draws wheel
  ────────────────────────────────────────────────────────── */
  function initLayout() {
    const door  = document.getElementById('wheelDoor');
    const stage = document.getElementById('wheelStage');
    const wSize = stage.offsetWidth;

    // Remove any stale frame from previous resize
    const oldFrame = door.querySelector('.frame-svg');
    if (oldFrame) oldFrame.remove();

    door.insertAdjacentHTML('beforeend', buildFrameSVG(wSize));
    buildLever();
    drawWheel();       // initial draw (hubBloom=0 → hub invisible)
    startHubBloom();   // then bloom the flower open over 2.2s
  }

  // Debounced resize handler
  let resizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(initLayout, 120);
  });

  window.addEventListener('load', () => {
    renderPools();         // populate envelope modal pools (even if hidden)
    initTimeSlider();      // wire up time snap-slider
    initLayout();          // frame + lever + first wheel draw
  });

  </script>
</body>
