<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Grimoire of Unfinished Thangs</title>
  <link
    href="https://fonts.googleapis.com/css2?family=UnifrakturMaguntia&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Courier+Prime:ital,wght@0,400;0,700;1,400&display=swap"
    rel="stylesheet">

  <style>
    /* =================================================================
       §1  DESIGN TOKENS
       All colours, typography and spacing live here.
       Update this section to retheme the entire product.
    ================================================================= */
    :root {
      /* Palette */
      --color-bg:        #000F01;   /* deep forest black */
      --color-lime:      #C9FF4B;   /* primary accent – electric lime */
      --color-red:       #FF0004;   /* danger / fermentation category */
      --color-orange:    #FF6600;   /* warm accent */
      --color-cream:     #FCFFDD;   /* light text / paper */
      --color-navy:      #010D25;   /* dark segment fill */
      --color-darkgreen: #1a3300;   /* mid-dark segment fill */
      --color-midgreen:  #2a4400;   /* mid segment fill */
      --color-brightgrn: #7acc10;   /* bright segment accent */
      --color-softgrn:   #e8ff90;   /* pale segment accent */

      /* Semantic aliases */
      --ink:    var(--color-cream);
      --accent: var(--color-lime);
      --bg:     var(--color-bg);

      /* Transparency ramp of lime accent */
      --dim:     rgba(201,255,75, 0.45);
      --dimmer:  rgba(201,255,75, 0.18);
      --dimmest: rgba(201,255,75, 0.07);

      /* Typography */
      --font-display: 'UnifrakturMaguntia', cursive;
      --font-serif:   'Cormorant Garamond', serif;
      --font-mono:    'Courier Prime', monospace;

      /* Z-index stack */
      --z-bg:       0;
      --z-page:     1;
      --z-sparkle:  2;
      --z-wheel:    2;
      --z-lever:    10;
      --z-frame:    4;
      --z-toast:    400;
      --z-confetti: 300;
      --z-modal:    500;

      /* Spacing scale (used inline where clamp isn't practical) */
      --space-xs: 0.4rem;
      --space-sm: 0.8rem;
      --space-md: 1.6rem;
      --space-lg: 3rem;
    }


    /* =================================================================
       §2  RESET + BASE
    ================================================================= */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      background: var(--color-bg);
      min-height: 100vh;
      color: var(--ink);
      font-family: var(--font-mono);
      overflow-x: hidden;
    }


    /* =================================================================
       §3  BACKGROUND CANVASES
       Three fixed full-viewport canvases layered behind everything.
       borderCanvas  – animated growing ornate border (z:0)
       sparkleCanvas – ambient floating star particles (z:2)
       confettiCanvas – burst on quest complete (z:300)
    ================================================================= */
    #borderCanvas,
    #sparkleCanvas,
    #confettiCanvas {
      position: fixed;
      inset: 0;
      width: 100vw;
      height: 100vh;
      pointer-events: none;
    }

    #borderCanvas  { z-index: var(--z-bg); }
    #sparkleCanvas { z-index: var(--z-sparkle); }
    #confettiCanvas{ z-index: var(--z-confetti); }


    /* =================================================================
       §4  PAGE LAYOUT
    ================================================================= */
    .page {
      position: relative;
      z-index: var(--z-page);
      max-width: 960px;
      margin: 0 auto;
      padding: 2.8rem 1.5rem 5rem;
    }

    @media (max-width: 600px) {
      .page { padding: 1.8rem 0.8rem 3rem; }
    }


    /* =================================================================
       §5  HEADER
    ================================================================= */
    header {
      text-align: center;
      padding-bottom: 2.4rem;
    }

    .site-title {
      font-family: var(--font-display);
      font-size: clamp(1.6rem, 4.5vw, 3.4rem);
      color: var(--color-lime);
      letter-spacing: 0.04em;
      line-height: 1.1;
      /* Layered glow: sharp halo + wide bloom + baseline drop-shadow */
      text-shadow:
        0 0 4px  rgba(201,255,75, 0.7),
        0 0 60px rgba(201,255,75, 0.2),
        0 1px 0  rgba(0,0,0, 0.9);
    }

    .site-sub {
      font-family: var(--font-serif);
      font-style: italic;
      font-weight: 300;
      font-size: clamp(0.65rem, 1.5vw, 0.85rem);
      letter-spacing: 0.14em;
      color: var(--dim);
      margin-top: 0.55rem;
    }


    /* =================================================================
       §6  TIME SLIDER
       A 5-stop snap slider (5min → 2h+) replacing the old button group.
       The knob is a custom octagonal SVG rendered inline.
    ================================================================= */
    .time-slider-wrap {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.6rem;
      margin-bottom: 4.5rem;
    }

    /* Selected slot label (large, display font) */
    .time-slot-name {
      font-family: var(--font-display);
      font-size: 0.95rem;
      color: var(--color-lime);
      letter-spacing: 0.08em;
      height: 1.4em;           /* reserve fixed height to prevent layout shift */
      text-shadow: 0 0 12px rgba(201,255,75, 0.5);
    }

    /* Interactive track area */
    .time-slider-track {
      position: relative;
      width: min(300px, 68vw);
      height: 22px;           /* hit target height */
      display: flex;
      align-items: center;
      cursor: pointer;
    }

    /* Background rail */
    .time-slider-rail {
      position: absolute;
      inset: 0;
      height: 2px;
      margin: auto 0;
      background: var(--dimmer);
      border-radius: 2px;
    }

    /* Fill from left to knob position */
    .time-slider-fill {
      position: absolute;
      left: 0;
      top: 50%;
      transform: translateY(-50%);
      height: 2px;
      background: linear-gradient(to right, rgba(201,255,75, 0.4), var(--color-lime));
      border-radius: 2px;
      pointer-events: none;
    }

    /* Tick marks at each stop */
    .time-slider-ticks {
      position: absolute;
      inset: 0;
      display: flex;
      justify-content: space-between;
      align-items: center;
      pointer-events: none;
    }

    .time-slider-tick       { width: 1px;  height: 7px;  background: var(--dimmer); }
    .time-slider-tick.major { height: 11px; background: rgba(201,255,75, 0.35); }

    /* Draggable octagonal knob */
    .time-slider-knob {
      position: absolute;
      width: 24px;
      height: 24px;
      transform: translateX(-50%);
      cursor: grab;
      z-index: 2;
    }

    .time-slider-knob:active { cursor: grabbing; }

    .time-slider-knob svg {
      filter: drop-shadow(0 0 5px rgba(201,255,75, 0.5));
    }

    /* Label row below track */
    .time-slider-labels {
      display: flex;
      justify-content: space-between;
      width: min(300px, 68vw);
      font-family: var(--font-mono);
      font-size: 0.5rem;
      letter-spacing: 0.1em;
      color: var(--dimmer);
    }

    .time-slider-labels .active-lbl { color: var(--color-lime); }


    /* =================================================================
       §7  WHEEL ZONE
       Structure:
         .wheel-zone
           .wheel-and-lever
             .wheel-door           ← ornamental frame is injected here by JS
               .wheel-stage
                 canvas#wheel      ← 800×800 canvas, scaled via CSS
                 .lever-arc-wrap   ← quarter-arc lever SVG (JS-built)
                 .wheel-ptr        ← decorative indicator arrow
    ================================================================= */
    .wheel-zone {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .wheel-and-lever {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
    }

    /* Ornamental frame SVG is absolutely positioned outside wheel-stage */
    .wheel-door {
      position: relative;
      display: inline-flex;
      justify-content: center;
      align-items: center;
    }

    .frame-svg {
      position: absolute;
      pointer-events: none;
      z-index: var(--z-frame);
      filter: drop-shadow(0 0 12px rgba(201,255,75, 0.22));
    }

    /* Wheel canvas stage – all overlays are children of this element */
    .wheel-stage {
      position: relative;
      width: min(480px, 78vw);
      aspect-ratio: 1;
      z-index: var(--z-wheel);
    }

    #wheel {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      display: block;
      filter:
        drop-shadow(0 0 30px rgba(201,255,75, 0.12))
        drop-shadow(0 0 80px rgba(0,0,0, 0.6));
    }

    /* Quarter-arc lever track + knob (SVG injected by buildLever()) */
    .lever-arc-wrap {
      position: absolute;
      inset: 0;
      z-index: var(--z-lever);
      pointer-events: none;
      overflow: visible;  /* knob may extend beyond stage edge */
    }

    /* Indicator arrow – sits on the left edge of the wheel, points right */
    .wheel-ptr {
      position: absolute;
      top: 50%;
      left: -6px;
      transform: translateY(-50%);
      pointer-events: none;
      z-index: var(--z-lever);
    }


    /* =================================================================
       §8  PAMPHLET MODAL
       Revealed when the wheel stops. Animates like a manuscript scroll
       unrolling, with the quest text written by an ink quill.

       Colour scheme: dark forest green (matches app palette),
       rollers in deep green with lime brass ends.
    ================================================================= */
    .pamphlet-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 8, 0, 0.96);
      z-index: var(--z-modal);
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.4s ease;
      backdrop-filter: blur(8px);
    }

    .pamphlet-overlay.open {
      opacity: 1;
      pointer-events: all;
    }

    /* Outer wrapper – click to close */
    .pamphlet-outer {
      position: relative;
      width: min(560px, 92vw);
      cursor: pointer;
    }

    /* Wooden scroll rollers (top + bottom) */
    .pamphlet-roller {
      width: 100%;
      height: 26px;
      background: linear-gradient(
        to bottom,
        #080f00, #1a2c00, #2a4400, #1a2c00, #080f00
      );
      border-radius: 13px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.9), inset 0 1px 0 rgba(201,255,75,0.15);
      position: relative;
      z-index: 2;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 8px;
    }

    /* Brass end-caps on each roller */
    .pamphlet-roller-end {
      width: 18px;
      height: 18px;
      border-radius: 50%;
      background: radial-gradient(circle at 35% 30%, #6acc20, #1a3c00);
      box-shadow: 0 2px 6px rgba(0,0,0,0.6), 0 0 8px rgba(201,255,75,0.2);
    }

    /* Scroll body – expands on .open via max-height transition */
    .pamphlet-body {
      background: linear-gradient(160deg, #040d00 0%, #061200 40%, #081800 100%);
      border-left:  1px solid rgba(201,255,75, 0.2);
      border-right: 1px solid rgba(201,255,75, 0.2);
      margin: 0 18px;
      position: relative;
      z-index: 1;
      overflow: hidden;
      max-height: 0;
      transition: max-height 0.9s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .pamphlet-overlay.open .pamphlet-body { max-height: 560px; }

    /* Inner content – fades in after scroll has unrolled. */
    .pamphlet-inner {
      position: relative;
      padding: 2.2rem 2.8rem 2rem;
      opacity: 0;
      transition: opacity 0.5s 0.55s;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 240px;
    }

    .pamphlet-overlay.open .pamphlet-inner { opacity: 1; }

    /* Decorative double-rule borders */
    .pamphlet-border {
      border-top:    1.5px solid rgba(201,255,75, 0.3);
      border-bottom: 1.5px solid rgba(201,255,75, 0.3);
      padding: 0.8rem 0;
      margin: 0.6rem 0;
      width: 100%;
    }

    .pamphlet-border-inner {
      border-top:    1px solid rgba(201,255,75, 0.12);
      border-bottom: 1px solid rgba(201,255,75, 0.12);
      padding: 0.5rem 0;
    }

    /* "THY QUEST IS REVEALED" eyebrow label */
    .pamphlet-label {
      font-family: var(--font-mono);
      font-size: 0.5rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(201,255,75, 0.4);
      text-align: center;
      margin-bottom: 0.9rem;
    }

    /* Quest category + theme row — side by side, same weight/size */
    .pamphlet-meta {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.6rem;
      margin-bottom: 0.5rem;
      flex-wrap: wrap;
    }

    /* Category and theme share identical typography */
    .pamphlet-category,
    .pamphlet-theme {
      font-family: var(--font-display);
      font-size: 1.1rem;
      letter-spacing: 0.05em;
      color: var(--color-lime);
      text-shadow: 0 0 18px rgba(201,255,75, 0.65);
    }

    .pamphlet-cat-icon {
      font-size: 1.2rem;
      line-height: 1;
    }

    .pamphlet-meta-sep {
      color: rgba(201,255,75, 0.4);
      font-family: var(--font-serif);
      font-size: 1rem;
    }

    /* Selected time slot shown below meta row */
    .pamphlet-time {
      font-family: var(--font-mono);
      font-size: 0.52rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(201,255,75, 0.38);
      margin-bottom: 0.2rem;
    }

    /* Main quest text container */
    .pamphlet-quest {
      font-family: var(--font-serif);
      font-size: clamp(1.4rem, 4.5vw, 2.2rem);
      font-style: italic;
      font-weight: 500;
      color: var(--color-lime);
      text-align: center;
      line-height: 1.35;
      min-height: 3em;
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      text-shadow: 0 0 20px rgba(201,255,75, 0.3);
    }

    /*
      Ink-writing animation:
      clip-path slides from full-right to full-left, revealing text
      as if being written. Triggered by .open on the overlay.
    */
    .pamphlet-quest-text {
      display: inline;
      clip-path: inset(0 100% 0 0);
      transition: clip-path 1.8s cubic-bezier(0.22, 1, 0.36, 1) 0.7s;
    }

    .pamphlet-overlay.open .pamphlet-quest-text {
      clip-path: inset(0 0% 0 0);
    }

    /* Blinking quill cursor that fades after writing completes */
    .pamphlet-quill {
      display: inline-block;
      font-size: 1rem;
      opacity: 0;
      color: rgba(201,255,75, 0.7);
    }

    .pamphlet-overlay.open .pamphlet-quill {
      opacity: 1;
      animation: quillBlink 0.7s steps(1) 0.7s 6;
    }

    @keyframes quillBlink {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0; }
    }

    /* Pamphlet action buttons — sit outside the scroll, below the bottom roller */
    .pamphlet-actions {
      display: flex;
      gap: 0.8rem;
      justify-content: center;
      margin-top: 1rem;
      flex-wrap: wrap;
    }

    .pamphlet-btn {
      font-family: var(--font-display);
      font-size: 0.85rem;
      letter-spacing: 0.04em;
      padding: 0.6rem 1.4rem;
      border-radius: 4px;
      cursor: pointer;
      border: 1px solid;
      transition: transform 0.15s, box-shadow 0.2s, opacity 0.2s;
    }

    .pamphlet-btn:hover { transform: scale(1.04); }
    .pamphlet-btn:active { transform: scale(0.97); }

    .pamphlet-btn-timer {
      background: var(--color-lime);
      color: var(--color-bg);
      border-color: var(--color-lime);
      box-shadow: 0 0 16px rgba(201,255,75, 0.3);
    }

    .pamphlet-btn-timer:hover {
      box-shadow: 0 0 28px rgba(201,255,75, 0.55);
    }

    .pamphlet-btn-respin {
      background: transparent;
      color: rgba(201,255,75, 0.75);
      border-color: rgba(201,255,75, 0.35);
    }

    .pamphlet-btn-respin:hover {
      border-color: rgba(201,255,75, 0.65);
      color: var(--color-lime);
      box-shadow: 0 0 14px rgba(201,255,75, 0.2);
    }

    /* Timer display — appears below pamphlet */
    .timer-wrap {
      width: min(560px, 92vw);
      margin-top: 0.8rem;
      text-align: center;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.4s;
    }

    .timer-wrap.visible {
      opacity: 1;
      pointer-events: all;
    }

    .timer-display {
      font-family: var(--font-display);
      font-size: clamp(3rem, 12vw, 5.5rem);
      color: var(--color-lime);
      letter-spacing: 0.08em;
      text-shadow: 0 0 30px rgba(201,255,75, 0.55), 0 0 80px rgba(201,255,75, 0.2);
      line-height: 1;
    }

    .timer-display.done {
      animation: timerPulse 0.6s ease infinite alternate;
    }

    @keyframes timerPulse {
      from { text-shadow: 0 0 20px rgba(201,255,75, 0.4); }
      to   { text-shadow: 0 0 60px rgba(201,255,75, 0.9), 0 0 120px rgba(201,255,75, 0.4); }
    }

    .timer-controls {
      display: flex;
      gap: 0.6rem;
      justify-content: center;
      margin-top: 0.7rem;
    }

    .timer-ctrl-btn {
      font-family: var(--font-mono);
      font-size: 0.6rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      padding: 0.4rem 1rem;
      background: transparent;
      border: 1px solid rgba(201,255,75, 0.3);
      color: rgba(201,255,75, 0.65);
      cursor: pointer;
      transition: border-color 0.2s, color 0.2s;
    }

    .timer-ctrl-btn:hover {
      border-color: rgba(201,255,75, 0.65);
      color: var(--color-lime);
    }
      margin-top: 0.6rem;
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 0.85rem;
      color: rgba(201,255,75, 0.5);
      text-align: center;
      line-height: 1.6;
    }

    /* Single SVG overlay handles all 4 corners — no fragile position:absolute children */
    .pamphlet-corners-svg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      opacity: 0.45;
    }

    /* Wax seal area */
    .pamphlet-seal {
      text-align: center;
      margin-top: 1rem;
      font-size: 0.55rem;
      letter-spacing: 0.22em;
      color: rgba(201,255,75, 0.3);
      font-family: var(--font-mono);
      text-transform: uppercase;
    }

    /* Seal icon spins in with a 180° rotation after a delay */
    .pamphlet-seal-icon {
      display: inline-block;
      font-size: 1.8rem;
      color: rgba(201,255,75, 0.5);
      text-shadow: 0 0 12px rgba(201,255,75, 0.4);
      animation: sealSpin 0.6s ease 1.5s both;
    }

    @keyframes sealSpin {
      from { transform: rotate(-180deg) scale(0); opacity: 0; }
      to   { transform: rotate(0deg)   scale(1); opacity: 1; }
    }

    /* "Tap anywhere to close" hint below rollers */
    .pamphlet-close-hint {
      text-align: center;
      margin-top: 0.6rem;
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 0.7rem;
      color: rgba(201,255,75, 0.3);
      letter-spacing: 0.1em;
    }

    /* Floating particle container (JS spawns .pp elements inside) */
    .pamphlet-particles {
      position: absolute;
      inset: 0;
      pointer-events: none;
      overflow: hidden;
      z-index: 10;
    }

    .pp {
      position: absolute;
      font-size: 14px;
      color: rgba(201,255,75, 0.6);
      opacity: 0;
      animation: particleFloat 3s ease-in-out infinite;
    }

    @keyframes particleFloat {
      0%   { opacity: 0;   transform: translateY(0)    rotate(0deg); }
      20%  { opacity: 0.8; }
      80%  { opacity: 0.4; }
      100% { opacity: 0;   transform: translateY(-80px) rotate(30deg); }
    }


    /* =================================================================
       §9  ENVELOPE MODAL (Prompt Generator)
       Kept in codebase; currently not linked from the stripped UI.
       Re-enable by adding a trigger button if needed.
    ================================================================= */
    .env-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,5,0, 0.92);
      z-index: 200;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.35s;
      backdrop-filter: blur(4px);
    }

    .env-overlay.open { opacity: 1; pointer-events: all; }

    .env-modal        { position: relative; display: flex; flex-direction: column; align-items: center; }
    .env-close        { position: absolute; top: -44px; right: -4px; background: none; border: none; color: var(--dim); font-size: 1.4rem; cursor: pointer; font-family: var(--font-serif); transition: color 0.2s; }
    .env-close:hover  { color: var(--color-lime); }
    .env-outer        { position: relative; width: 340px; height: 250px; }

    .env-body {
      position: absolute;
      bottom: 0; left: 0;
      width: 340px; height: 220px;
      background: var(--color-cream);
      overflow: visible;
    }

    .env-body::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        linear-gradient(135deg, #d4e8a0 0%, transparent 50%),
        linear-gradient(225deg, #b8d080 0%, transparent 50%),
        linear-gradient(315deg, #e4f0b4 0%, transparent 60%);
    }

    .env-body::after {
      content: '';
      position: absolute;
      inset: 0;
      background:
        linear-gradient(to bottom right, rgba(255,255,255,.12) 0%, transparent 50%),
        linear-gradient(to bottom left,  rgba(0,0,0,.08)       0%, transparent 50%);
    }

    .env-flap {
      position: absolute;
      top: 0; left: 0;
      width: 0; height: 0;
      border-left:  170px solid transparent;
      border-right: 170px solid transparent;
      border-top:   110px solid #a8cc40;
      transform-origin: top center;
      transition: transform 0.55s cubic-bezier(0.4,0,0.2,1);
      z-index: 6;
      filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
    }

    .env-flap.opened { transform: rotateX(185deg); }

    .env-seal {
      position: absolute;
      bottom: 18px; left: 50%;
      transform: translateX(-50%);
      width: 40px; height: 40px;
      border-radius: 50%;
      background: radial-gradient(circle at 35% 35%, #4a8820, #1a4800);
      display: flex; align-items: center; justify-content: center;
      font-size: 16px; z-index: 7;
      color: rgba(201,255,75, 0.9);
      box-shadow: 0 2px 8px rgba(0,0,0, 0.5);
      transition: opacity 0.4s;
    }

    /* Paper slips that fly out of the envelope */
    .paper {
      position: absolute;
      bottom: 10px; left: 50%;
      width: 290px; height: 190px;
      transform: translateX(-50%) translateY(0);
      transition: transform 0.6s cubic-bezier(0.34,1.3,0.64,1), opacity 0.4s;
      border: 1px solid rgba(1,13,37, 0.18);
      padding: 16px 18px 14px;
      z-index: 5; opacity: 0;
      box-shadow: 0 2px 12px rgba(0,0,0, 0.2);
    }

    .paper:nth-child(1) { background: #F0FFCE; z-index: 5; }
    .paper:nth-child(2) { background: #E8F5BE; z-index: 4; }
    .paper:nth-child(3) { background: #DDEAAE; z-index: 3; }

    .env-overlay.open .paper:nth-child(1) { opacity:1; transform: translateX(calc(-50% - 8px)) translateY(-230px) rotate(-5deg); }
    .env-overlay.open .paper:nth-child(2) { opacity:1; transform: translateX(-50%)               translateY(-200px) rotate(1deg); }
    .env-overlay.open .paper:nth-child(3) { opacity:1; transform: translateX(calc(-50% + 8px)) translateY(-170px) rotate(6deg); }

    .paper-label      { font-size:.5rem; letter-spacing:.2em; text-transform:uppercase; color:#2a5010; margin-bottom:6px; font-family: var(--font-mono); }
    .paper-val        { font-family: var(--font-serif); font-style:italic; font-size:1rem; color:#010D25; min-height:28px; line-height:1.4; }
    .paper-val.shuffling { color: rgba(1,13,37,.4); }
    .paper-empty-hint { font-family: var(--font-mono); font-style:normal; font-size:.65rem; color:rgba(1,13,37,.3); letter-spacing:.08em; }
    .paper-lines      { position:absolute; bottom:12px; left:18px; right:18px; }
    .paper-lines span { display:block; border-bottom:1px solid rgba(1,13,37,.07); height:18px; }

    .env-draw-btn         { margin-top:2.8rem; background:transparent; border:1px solid rgba(201,255,75,.45); color:var(--color-lime); font-family:var(--font-serif); font-style:italic; font-size:.95rem; padding:11px 32px; cursor:pointer; white-space:nowrap; transition:border-color .2s,box-shadow .2s,background .2s; }
    .env-draw-btn:hover   { border-color:var(--color-lime); box-shadow:0 0 20px rgba(201,255,75,.28); background:rgba(201,255,75,.06); }
    .env-draw-btn:disabled{ opacity:.4; cursor:not-allowed; }

    .env-pools             { margin-top:1.6rem; width:340px; display:grid; grid-template-columns:1fr 1fr 1fr; gap:1rem; }
    .pool-title            { font-size:.52rem; letter-spacing:.18em; text-transform:uppercase; color:var(--accent); margin-bottom:.4rem; }
    .pool-tags             { display:flex; flex-direction:column; gap:2px; max-height:90px; overflow-y:auto; }
    .pool-tags::-webkit-scrollbar { width:2px; }
    .pool-tags::-webkit-scrollbar-thumb { background:var(--dimmer); }
    .pool-tag              { font-size:10px; font-family:var(--font-mono); color:var(--dim); cursor:pointer; padding:2px 0; display:flex; align-items:center; justify-content:space-between; }
    .pool-tag:hover        { color:var(--color-lime); }
    .pool-tag .tx          { opacity:.28; }
    .pool-tag:hover .tx    { opacity:.7; color:#FF0004; }
    .pool-add              { display:flex; gap:4px; margin-top:.4rem; }
    .pool-add input        { flex:1; background:transparent; border:none; border-bottom:1px solid var(--dimmer); color:var(--color-lime); font-family:var(--font-mono); font-size:10px; padding:4px 2px; outline:none; min-width:0; }
    .pool-add input:focus  { border-color:var(--accent); }
    .pool-add input::placeholder { color:var(--dimmer); }
    .pool-add button       { background:none; border:none; color:var(--accent); font-size:14px; cursor:pointer; padding:2px 4px; transition:color .2s; }
    .pool-add button:hover { color:var(--color-lime); }


    /* =================================================================
       §10  SHARED MICRO-COMPONENTS
    ================================================================= */
    /* Underline input */
    .g-input {
      flex: 1;
      background: transparent;
      border: none;
      border-bottom: 1px solid var(--dimmer);
      padding: 6px 2px;
      color: var(--ink);
      font-family: var(--font-mono);
      font-size: 11px;
      outline: none;
      transition: border-color 0.2s;
    }

    .g-input:focus       { border-color: var(--accent); }
    .g-input::placeholder{ color: var(--dimmer); }

    /* Icon button (single character, underline style) */
    .g-btn       { background:transparent; border:none; border-bottom:1px solid var(--dimmer); color:var(--accent); font-size:16px; padding:3px 10px; cursor:pointer; transition:color .2s; }
    .g-btn:hover { color: var(--ink); }

    /* Toast notification */
    .toast {
      position: fixed;
      bottom: 2rem;
      left: 50%;
      transform: translateX(-50%) translateY(100px);
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 0.9rem;
      color: var(--bg);
      background: var(--color-lime);
      padding: 9px 24px;
      z-index: var(--z-toast);
      white-space: nowrap;
      clip-path: polygon(6px 0%,calc(100% - 6px) 0%,100% 6px,100% calc(100% - 6px),calc(100% - 6px) 100%,6px 100%,0% calc(100% - 6px),0% 6px);
      transition: transform 0.45s cubic-bezier(0.34, 1.4, 0.64, 1);
    }

    .toast.show { transform: translateX(-50%) translateY(0); }

    /* Floating FX characters (✦ ✧ ⁂ etc.) spawned by JS */
    .fx-char {
      position: fixed;
      pointer-events: none;
      z-index: 5;
      font-size: 14px;
      color: var(--color-lime);
      opacity: 0;
      animation: fxFloat 2.5s ease-out forwards;
    }

    @keyframes fxFloat {
      0%   { opacity: 0.8; transform: translateY(0); }
      100% { opacity: 0;   transform: translateY(-65px); }
    }
  </style>
</head>

